{%- comment -%}
  Frequently Bought Together — Horizontal (u3rw3o3e).

  Same selection / variant-modal / batched cart-add behaviour as the
  vertical sibling (l2dcg7yd). Differences are presentational only:
    - Cards laid out horizontally with `+` separators between them.
    - Right-side Total panel that sums selected variant prices live and
      hosts the aggregate Add To Cart button.

  Wrapper contract — render args:
    - entry              : SlotEnvelope entry from spectrum.fbt_<draft|live>;
                           `entry.content.recommendations` is an array of
                           product handles the wrapper resolved as the
                           default content for this product. Single source
                           of truth for which products render as recos.
    - variant            : default variant from the spectrum_snippet_instance
                           metaobject; `variant.content` carries the merchant-
                           edited props (heading, cta_label, total_label, …).
    - mo                 : spectrum_snippet_instance metaobject drop.
    - mutation_handle    : 'mut-{instanceId}' — consumed by the wrapper's
                           outer div, not by this snippet body.
    - experience_handle  : consumed by the wrapper's outer div.

  Liquid globals used inside this snippet (NOT render args — Shopify-native):
    - product            : the page's main product (PDP context).
    - all_products       : handle-keyed product lookup. Capped at 20 unique
                           handles per page — well above the FBT count.
    - shop               : currency code threaded into the JSON payload.

  Empty / nil `entry.content.recommendations` collapses the whole widget.
{%- endcomment -%}

{%- assign content       = variant.content -%}
{%- assign heading       = content.heading       | default: 'Frequently Bought Together' -%}
{%- assign cta_label     = content.cta_label     | default: 'Add To Cart' -%}
{%- assign total_label   = content.total_label   | default: 'Total' -%}
{%- assign total_subtext = content.total_subtext | default: 'Selected items will be added to cart.' -%}
{%- assign lock_main = content.lock_main_product -%}
{%- if lock_main == nil -%}{%- assign lock_main = false -%}{%- endif -%}
{%- assign show_total_price = content.show_total_price -%}
{%- if show_total_price == nil -%}{%- assign show_total_price = true -%}{%- endif -%}
{%- assign section_description = content.section_description | default: '' -%}
{%- assign show_discount_badge = content.show_discount_badge -%}
{%- if show_discount_badge == nil -%}{%- assign show_discount_badge = true -%}{%- endif -%}

{%- comment -%}
  Select-prop allowlists. `| default:` is not enough — validate against
  the allowed set and fall back to the safe default (fail-closed per
  .claude/rules/generated-liquid.md "Default-to-safe on missing/invalid
  render arguments").
{%- endcomment -%}
{%- assign checkbox_default_state = content.checkbox_default_state -%}
{%- if checkbox_default_state != 'selected' and checkbox_default_state != 'unselected' -%}
  {%- assign checkbox_default_state = 'selected' -%}
{%- endif -%}
{%- assign default_checked = true -%}
{%- if checkbox_default_state == 'unselected' -%}{%- assign default_checked = false -%}{%- endif -%}

{%- assign image_aspect_ratio = content.image_aspect_ratio -%}
{%- if image_aspect_ratio != '1:1' and image_aspect_ratio != '4:3' and image_aspect_ratio != '3:4' -%}
  {%- assign image_aspect_ratio = '1:1' -%}
{%- endif -%}
{%- assign aspect_css = '1' -%}
{%- if image_aspect_ratio == '4:3' -%}{%- assign aspect_css = '4 / 3' -%}{%- endif -%}
{%- if image_aspect_ratio == '3:4' -%}{%- assign aspect_css = '3 / 4' -%}{%- endif -%}

{%- assign image_object_fit = content.image_object_fit -%}
{%- if image_object_fit != 'cover' and image_object_fit != 'contain' -%}
  {%- assign image_object_fit = 'cover' -%}
{%- endif -%}

{%- assign image_style = 'aspect-ratio: ' | append: aspect_css | append: '; object-fit: ' | append: image_object_fit | append: ';' -%}

{%- assign fbt_handles = entry.content.recommendations -%}

{%- comment -%}
  Pre-pass: count handles that resolve to a real product drop.
  `all_products[h]` returns EmptyDrop (NOT nil) for unknown handles, so
  the safe test is `r == empty`. Used as the collapse gate so a payload
  consisting entirely of stale handles renders nothing.
{%- endcomment -%}
{%- assign resolved_count = 0 -%}
{%- if fbt_handles != nil -%}
  {%- for handle in fbt_handles -%}
    {%- assign r = all_products[handle] -%}
    {%- unless r == empty -%}
      {%- assign resolved_count = resolved_count | plus: 1 -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}

{%- if resolved_count == 0 -%}
  {%- comment -%} no recos — collapse widget; do not emit the script tag {%- endcomment -%}
{%- else -%}

<script src="{{ 'sai-snippet-u3rw3o3e.js' | asset_url }}" async></script>

<sai-u3rw3o3e class="sai-u3rw3o3e">
  <div class="sai-u3rw3o3e__inner">
  <h2 class="sai-u3rw3o3e__heading">{{ heading }}</h2>
  {%- if section_description != blank -%}
    <p class="sai-u3rw3o3e__description">{{ section_description }}</p>
  {%- endif -%}

  <div class="sai-u3rw3o3e__layout">
    <div class="sai-u3rw3o3e__cards">

      {%- comment -%} ── Main product card — same chrome as recos. {%- endcomment -%}
      <div class="sai-u3rw3o3e__card sai-u3rw3o3e__card--main" data-product-id="{{ product.id }}">
        <label class="sai-u3rw3o3e__checkbox{% if lock_main %} sai-u3rw3o3e__checkbox--locked{% endif %}">
          <input type="checkbox" data-fbt-checkbox
            {% if lock_main or default_checked %}checked{% endif %}
            aria-label="Include {{ product.title | escape }}"
            {% if lock_main %}disabled{% endif %}>
          <span class="sai-u3rw3o3e__checkbox-mark" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false">
              <path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </label>
        <a class="sai-u3rw3o3e__media" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
          {%- if product.featured_image -%}
            <img
              class="sai-u3rw3o3e__image"
              src="{{ product.featured_image | image_url: width: 400 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              style="{{ image_style }}"
              loading="lazy"
            >
          {%- endif -%}
        </a>
        <a class="sai-u3rw3o3e__title" href="{{ product.url }}">{{ product.title }}</a>
        <div class="sai-u3rw3o3e__price-row">
          <span class="sai-u3rw3o3e__price">{{ product.price | money }}</span>
          {%- if product.compare_at_price and product.compare_at_price > product.price -%}
            <span class="sai-u3rw3o3e__compare">{{ product.compare_at_price | money }}</span>
            {%- if show_discount_badge -%}
              {%- assign p_off_amount = product.compare_at_price | minus: product.price -%}
              {%- assign p_off_pct = p_off_amount | times: 100 | divided_by: product.compare_at_price -%}
              <span class="sai-u3rw3o3e__off-badge">{{ p_off_pct }}% OFF</span>
            {%- endif -%}
          {%- endif -%}
        </div>
        {%- if product.variants.size > 1 -%}
          <button
            type="button"
            class="sai-u3rw3o3e__variant-trigger"
            data-variant-trigger
            aria-haspopup="dialog"
          >
            <span class="sai-u3rw3o3e__variant-label">{{ product.variants.first.options.first }}</span>
            <svg class="sai-u3rw3o3e__chevron" width="12" height="12" viewBox="0 0 14 14" fill="none" focusable="false" aria-hidden="true">
              <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}
      </div>

      {%- comment -%} ── Reco cards. `+` separator only between main and the
            first reco; subsequent recos sit next to each other separated only
            by the cards-container gap. {%- endcomment -%}
      {%- for handle in fbt_handles -%}
        {%- assign r = all_products[handle] -%}
        {%- if r == empty -%}{%- continue -%}{%- endif -%}
        {%- if forloop.first -%}
          <div class="sai-u3rw3o3e__plus" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false">
              <path d="M7 2V12M2 7H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
        {%- endif -%}
        <div class="sai-u3rw3o3e__card sai-u3rw3o3e__card--reco" data-product-id="{{ r.id }}">
          <label class="sai-u3rw3o3e__checkbox">
            <input type="checkbox" data-fbt-checkbox {% if default_checked %}checked{% endif %} aria-label="Include {{ r.title | escape }}">
            <span class="sai-u3rw3o3e__checkbox-mark" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false">
                <path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </label>
          <a class="sai-u3rw3o3e__media" href="{{ r.url }}" tabindex="-1" aria-hidden="true">
            {%- if r.featured_image -%}
              <img
                class="sai-u3rw3o3e__image"
                src="{{ r.featured_image | image_url: width: 400 }}"
                alt="{{ r.featured_image.alt | default: r.title | escape }}"
                style="{{ image_style }}"
                loading="lazy"
              >
            {%- endif -%}
          </a>
          <a class="sai-u3rw3o3e__title" href="{{ r.url }}">{{ r.title }}</a>
          <div class="sai-u3rw3o3e__price-row">
            <span class="sai-u3rw3o3e__price">{{ r.price | money }}</span>
            {%- if r.compare_at_price and r.compare_at_price > r.price -%}
              <span class="sai-u3rw3o3e__compare">{{ r.compare_at_price | money }}</span>
              {%- if show_discount_badge -%}
                {%- assign r_off_amount = r.compare_at_price | minus: r.price -%}
                {%- assign r_off_pct = r_off_amount | times: 100 | divided_by: r.compare_at_price -%}
                <span class="sai-u3rw3o3e__off-badge">{{ r_off_pct }}% OFF</span>
              {%- endif -%}
            {%- endif -%}
          </div>
          {%- if r.variants.size > 1 -%}
            <button
              type="button"
              class="sai-u3rw3o3e__variant-trigger"
              data-variant-trigger
              aria-haspopup="dialog"
            >
              <span class="sai-u3rw3o3e__variant-label">{{ r.variants.first.options.first }}</span>
              <svg class="sai-u3rw3o3e__chevron" width="12" height="12" viewBox="0 0 14 14" fill="none" focusable="false" aria-hidden="true">
                <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <aside class="sai-u3rw3o3e__total">
      {%- if show_total_price -%}
        <div class="sai-u3rw3o3e__total-label">{{ total_label }}</div>
        <div class="sai-u3rw3o3e__total-row">
          <div class="sai-u3rw3o3e__total-subtext">{{ total_subtext }}</div>
          <div class="sai-u3rw3o3e__total-amount" data-fbt-total></div>
        </div>
      {%- endif -%}
      <button type="button" class="sai-u3rw3o3e__cta" data-fbt-cta>
        <span data-fbt-cta-label>{{ cta_label }}</span>
      </button>
      <div class="sai-u3rw3o3e__error" data-fbt-error role="alert" hidden></div>
    </aside>
  </div>
  </div>

  {%- comment -%}
    JSON payload. Per-value `| json` is mandatory inside <script type="application/json">:
    Liquid's `| json` filter unicode-escapes `<`, `>`, line separators, so values
    that contain `</script>` or `<!--` survive intact as JSON but cannot terminate
    the surrounding <script> element. Integer ids are quoted as object keys
    manually because `| json` on a number emits unquoted digits (invalid JSON keys).
  {%- endcomment -%}
  <script type="application/json" data-fbt-payload>
{
  "main": {{ product.id | json }},
  "currency": {{ shop.currency | json }},
  "order": [{{ product.id | json }}{%- for handle in fbt_handles -%}{%- assign r = all_products[handle] -%}{%- if r == empty -%}{%- continue -%}{%- endif -%},{{ r.id | json }}{%- endfor -%}],
  "products": {
    "{{ product.id }}": {
      "id": {{ product.id | json }},
      "title": {{ product.title | json }},
      "url": {{ product.url | json }},
      "imageUrl": {%- if product.featured_image -%}{{ product.featured_image | image_url: width: 400 | json }}{%- else -%}null{%- endif -%},
      "price": {{ product.price | json }},
      "compareAtPrice": {{ product.compare_at_price | json }},
      "options": {{ product.options | json }},
      "available": {{ product.available | json }},
      "variants": [
        {%- for v in product.variants -%}
          {%- unless forloop.first -%},{%- endunless -%}
          {
            "id": {{ v.id | json }},
            "title": {{ v.title | json }},
            "price": {{ v.price | json }},
            "compareAtPrice": {{ v.compare_at_price | json }},
            "available": {{ v.available | json }},
            "options": {{ v.options | json }},
            "inventoryQty": {{ v.inventory_quantity | json }},
            "inventoryManaged": {{ v.inventory_management | json }}
          }
        {%- endfor -%}
      ]
    }
    {%- for handle in fbt_handles -%}
    {%- assign r = all_products[handle] -%}
    {%- if r == empty -%}{%- continue -%}{%- endif -%}
    ,
    "{{ r.id }}": {
      "id": {{ r.id | json }},
      "title": {{ r.title | json }},
      "url": {{ r.url | json }},
      "imageUrl": {%- if r.featured_image -%}{{ r.featured_image | image_url: width: 400 | json }}{%- else -%}null{%- endif -%},
      "price": {{ r.price | json }},
      "compareAtPrice": {{ r.compare_at_price | json }},
      "options": {{ r.options | json }},
      "available": {{ r.available | json }},
      "variants": [
        {%- for v in r.variants -%}
          {%- unless forloop.first -%},{%- endunless -%}
          {
            "id": {{ v.id | json }},
            "title": {{ v.title | json }},
            "price": {{ v.price | json }},
            "compareAtPrice": {{ v.compare_at_price | json }},
            "available": {{ v.available | json }},
            "options": {{ v.options | json }},
            "inventoryQty": {{ v.inventory_quantity | json }},
            "inventoryManaged": {{ v.inventory_management | json }}
          }
        {%- endfor -%}
      ]
    }
    {%- endfor -%}
  }
}
  </script>
</sai-u3rw3o3e>

{%- endif -%}
