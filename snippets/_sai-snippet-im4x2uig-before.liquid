{%- comment -%}
  Product Gallery V2 — spotlight + thumbnail strip gallery for PDP pages.

  Reads media from product metafields (spectrum.media_assets +
  spectrum.media_slots) per the Media Liquid Metafields contract.

  Desktop: vertical thumbnail strip on left, large spotlight on right
  with chevron navigation.
  Mobile: full-width spotlight with left/right chevrons, carousel dots below.
  Lightbox: white background, all filtered images stacked vertically.
{%- endcomment -%}

{% stylesheet %}
/* ── Product Gallery V2 ── */

.sai-im4x2uig {
  display: block;
  width: 100%;
  position: relative;
}

/* ── Select model CTA ── */

.sai-im4x2uig__select-model {
  position: absolute;
  bottom: var(--sai-size-3);
  right: var(--sai-size-3);
  z-index: 2;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 10%, transparent);
  border-radius: 999px;
  background: var(--sai-color-bg, #fff);
  color: var(--sai-color-fg, #000);
  cursor: pointer;
  display: none;
  align-items: center;
  height: 36px;
  gap: 6px;
  padding: 0 14px;
  font-family: var(--sai-font-body, inherit);
  font-size: 0.8125rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  line-height: 1;
  white-space: nowrap;
  transition: background var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out);
}

.sai-im4x2uig__select-model[data-has-filters] {
  display: flex;
}

.sai-im4x2uig__select-model:hover {
  opacity: 0.8;
}

/* ── Video play/pause overlay ── */

.sai-im4x2uig__video-play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: none;
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 40%, transparent));
  color: var(--sai-color-bg);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: opacity var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out),
    background var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out);
  opacity: 0;
  pointer-events: auto;
}

.sai-im4x2uig__video-play[data-visible] {
  opacity: 1;
}

.sai-im4x2uig__spotlight-wrap:hover .sai-im4x2uig__video-play,
.sai-im4x2uig__mobile-spotlight-wrap:hover .sai-im4x2uig__video-play,
.sai-im4x2uig__lightbox-main:hover .sai-im4x2uig__video-play {
  opacity: 0.8;
}

.sai-im4x2uig__video-play:hover {
  opacity: 1 !important;
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 55%, transparent));
}

@media (hover: none) {
  .sai-im4x2uig__video-play {
    opacity: 0.7;
  }
}

/* ── Video mute button ── */

.sai-im4x2uig__video-mute {
  position: absolute;
  bottom: var(--sai-size-3);
  left: var(--sai-size-3);
  z-index: 2;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 40%, transparent));
  color: var(--sai-color-bg);
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: opacity var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out),
    background var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out);
}

.sai-im4x2uig__video-mute[data-visible] {
  display: flex;
}

.sai-im4x2uig__video-mute:hover {
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 55%, transparent));
}

@media (hover: none) {
  .sai-im4x2uig__video-mute[data-visible] {
    display: flex;
  }
}

:has(> .sai-im4x2uig__zoom-trigger:not([style*="display: none"])) > .sai-im4x2uig__video-mute {
  bottom: calc(var(--sai-size-3) + 44px);
}

/* ── Filter dialog ── */

.sai-im4x2uig__filter-dialog {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  z-index: 9999;
  display: none;
}

.sai-im4x2uig__filter-dialog[open] {
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sai-im4x2uig__filter-dialog::backdrop {
  background: color-mix(in srgb, var(--sai-color-fg, #000) 40%, transparent);
  -webkit-backdrop-filter: blur(2px);
  backdrop-filter: blur(2px);
}

/* ── Filter panel ── */

.sai-im4x2uig__filter-panel {
  background: var(--sai-color-bg, #fff);
  color: var(--sai-color-fg, #000);
  border-radius: 12px 12px 0 0;
  padding: 0;
  width: 100%;
  max-height: 60vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -4px 24px color-mix(in srgb, var(--sai-color-fg, #000) 12%, transparent);
}

@media (min-width: 768px) {
  .sai-im4x2uig__filter-dialog[open] {
    align-items: center;
  }

  .sai-im4x2uig__filter-panel {
    border-radius: 12px;
    min-width: 360px;
    max-width: 440px;
    max-height: 70vh;
    box-shadow: 0 8px 32px color-mix(in srgb, var(--sai-color-fg, #000) 15%, transparent);
  }
}

.sai-im4x2uig__filter-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 8%, transparent);
  flex-shrink: 0;
}

.sai-im4x2uig__filter-panel-title {
  font-family: var(--sai-font-heading, inherit);
  font-size: 1.125rem;
  font-weight: var(--sai-font-heading-weight, 600);
  color: var(--sai-color-fg, #000);
  margin: 0;
}

.sai-im4x2uig__filter-panel-clear {
  border: none;
  background: none;
  color: var(--sai-color-fg, #000);
  font-family: var(--sai-font-body, inherit);
  font-size: 0.9375rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  cursor: pointer;
  opacity: 0.6;
  padding: 4px 0;
  text-decoration: underline;
}

.sai-im4x2uig__filter-panel-clear:hover {
  opacity: 1;
}

.sai-im4x2uig__filter-panel-body {
  flex: 1;
  overflow-y: auto;
  padding: 0;
}

.sai-im4x2uig__filter-panel-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
  padding: 12px 20px;
  border-top: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 8%, transparent);
  flex-shrink: 0;
}

.sai-im4x2uig__filter-panel-cancel,
.sai-im4x2uig__filter-panel-apply {
  padding: 8px 20px;
  border-radius: var(--sai-radius-md, 8px);
  font-family: var(--sai-font-body, inherit);
  font-size: 0.875rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  cursor: pointer;
}

.sai-im4x2uig__filter-panel-cancel {
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 15%, transparent);
  color: var(--sai-color-fg, #000);
}

.sai-im4x2uig__filter-panel-cancel:hover {
  background: color-mix(in srgb, var(--sai-color-fg, #000) 5%, transparent);
}

.sai-im4x2uig__filter-panel-apply {
  background: var(--sai-color-fg, #000);
  border: none;
  color: var(--sai-color-bg, #fff);
}

.sai-im4x2uig__filter-panel-apply:hover {
  opacity: 0.9;
}

/* ── Filters inside panel ── */

.sai-im4x2uig__filters {
  display: flex;
  flex-direction: column;
  gap: 20px;
  padding: 0;
}

/* ── Filter tabs ── */

.sai-im4x2uig__filter-tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 8%, transparent);
  padding: 0 20px;
  overflow-x: auto;
  scrollbar-width: none;
}

.sai-im4x2uig__filter-tabs::-webkit-scrollbar {
  display: none;
}

.sai-im4x2uig__filter-tab {
  padding: 10px 16px;
  border: none;
  background: transparent;
  color: var(--sai-color-fg, #000);
  font-family: var(--sai-font-body, inherit);
  font-size: 0.875rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  cursor: pointer;
  opacity: 0.5;
  border-bottom: 2px solid transparent;
  text-transform: capitalize;
  display: flex;
  align-items: center;
  gap: 4px;
}

.sai-im4x2uig__filter-tab--active {
  opacity: 1;
  border-bottom-color: var(--sai-color-fg, #000);
}

.sai-im4x2uig__filter-tab-check {
  font-size: 0.75rem;
}

/* ── Filter content (per tab) ── */

.sai-im4x2uig__filter-content {
  display: none;
  padding: 16px 20px;
}

.sai-im4x2uig__filter-content--active {
  display: block;
}

/* ── Image/swatch grid ── */

.sai-im4x2uig__filter-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

@media (min-width: 768px) {
  .sai-im4x2uig__filter-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.sai-im4x2uig__filter-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 8px;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 10%, transparent);
  border-radius: 8px;
  background: color-mix(in srgb, var(--sai-color-fg, #000) 3%, transparent);
  cursor: pointer;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.sai-im4x2uig__filter-card:hover {
  border-color: color-mix(in srgb, var(--sai-color-fg, #000) 25%, transparent);
}

.sai-im4x2uig__filter-card--active {
  border-color: var(--sai-color-primary, #2563eb);
  background: color-mix(in srgb, var(--sai-color-primary, #2563eb) 8%, transparent);
}

.sai-im4x2uig__filter-card-image {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  border-radius: 4px;
}

.sai-im4x2uig__filter-card-swatch {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 4px;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 10%, transparent);
}

.sai-im4x2uig__filter-card-label {
  font-size: 0.8125rem;
  font-family: var(--sai-font-body, inherit);
  color: var(--sai-color-fg, #000);
  text-transform: capitalize;
  text-align: center;
}

/* ── Text/null pill chips ── */

.sai-im4x2uig__filter-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.sai-im4x2uig__filter-pill {
  display: inline-flex;
  align-items: center;
  height: 36px;
  padding: 0 16px;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 15%, transparent);
  border-radius: 999px;
  background: transparent;
  color: var(--sai-color-fg, #000);
  font-size: 0.875rem;
  font-family: var(--sai-font-body, inherit);
  cursor: pointer;
  text-transform: capitalize;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.sai-im4x2uig__filter-pill:hover {
  border-color: color-mix(in srgb, var(--sai-color-fg, #000) 35%, transparent);
}

.sai-im4x2uig__filter-pill--active {
  background: var(--sai-color-fg, #000);
  color: var(--sai-color-bg, #fff);
  border-color: var(--sai-color-fg, #000);
}

/* ── Footer summary ── */


@media (min-width: 768px) {
  .sai-im4x2uig__filter-panel-header {
    padding: 20px 24px;
  }

  .sai-im4x2uig__filter-panel-title {
    font-size: 1.25rem;
  }

  .sai-im4x2uig__filter-panel-clear {
    font-size: 0.9375rem;
  }

  .sai-im4x2uig__filter-panel-footer {
    padding: 20px 24px;
  }

  .sai-im4x2uig__filter-panel-cancel,
  .sai-im4x2uig__filter-panel-apply {
    font-size: 1rem;
    padding: 12px 20px;
  }
}

/* ── Empty state ── */

.sai-im4x2uig__empty {
  display: none;
  padding: 24px 0;
  text-align: center;
  font-size: 0.875rem;
  font-family: var(--sai-font-body, inherit);
  color: var(--sai-color-fg, #000);
  opacity: 0.6;
}

/* ── Spotlight wrap ── */

.sai-im4x2uig__spotlight-wrap,
.sai-im4x2uig__mobile-spotlight-wrap {
  position: relative;
  cursor: pointer;
}

/* ── Desktop layout ── */

.sai-im4x2uig__desktop {
  display: none;
  /* Query container so the thumbnail rail can size its max-height to the
     square spotlight's rendered height (see .__thumbs). */
  container-type: inline-size;
}

@media (min-width: 768px) {
  .sai-im4x2uig__desktop {
    display: grid;
    grid-template-columns: var(--sai-im4x2uig-thumb-size, 64px) 1fr;
    gap: var(--sai-size-3);
    align-items: start;
  }
}

/* ── Thumbnail strip (desktop) ── */

.sai-im4x2uig__thumbs {
  display: flex;
  flex-direction: column;
  gap: var(--sai-size-2);
  /* Cap the rail at whichever is shorter: the spotlight's rendered height, or
     `thumbnails-visible` thumbs. The spotlight is square and fills the grid's
     1fr track, so its height is the container inline size minus the thumb
     column and gap — `100cqw - thumb - gap`, resolved against
     `container-type: inline-size` on .__desktop. The count term lets a merchant
     make the rail shorter than the image; it can never make it taller. Beyond
     the cap, thumbs scroll. Without a cap the strip stacks every thumb and
     overflows the gallery, since the column track is sized by content. */
  max-height: min(
    calc(100cqw - var(--sai-im4x2uig-thumb-size, 64px) - var(--sai-size-3)),
    calc(
      var(--sai-im4x2uig-thumbs-visible, 20) * var(--sai-im4x2uig-thumb-size, 64px) +
      (var(--sai-im4x2uig-thumbs-visible, 20) - 1) * var(--sai-size-2)
    )
  );
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(0, 0, 0, 0.15) transparent;
}

.sai-im4x2uig__thumbs::-webkit-scrollbar {
  width: 3px;
}

.sai-im4x2uig__thumbs::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.15);
  border-radius: var(--sai-radius-round);
}

.sai-im4x2uig__thumb {
  flex-shrink: 0;
  width: var(--sai-im4x2uig-thumb-size, 64px);
  height: var(--sai-im4x2uig-thumb-size, 64px);
  padding: 0;
  border: 2px solid transparent;
  border-radius: 4px;
  background: var(--sai-color-bg);
  cursor: pointer;
  overflow: hidden;
  position: relative;
  transition: border-color var(--sai-duration-2) var(--sai-ease-out-1);
}

.sai-im4x2uig__thumb:hover {
  border-color: rgba(0, 0, 0, 0.2);
}

.sai-im4x2uig__thumb--active {
  border-color: var(--sai-im4x2uig-active-thumb-border, var(--sai-color-fg, #000));
}

.sai-im4x2uig__thumb-media {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: var(--sai-im4x2uig-thumb-fit, cover);
}

.sai-im4x2uig__thumb-play {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  color: #fff;
  pointer-events: none;
}

/* ── Spotlight (shared desktop + mobile) ── */

.sai-im4x2uig__spotlight-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 0;
  background: var(--sai-color-bg);
  cursor: pointer;
}

.sai-im4x2uig__spotlight {
  width: 100%;
  aspect-ratio: 1 / 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.sai-im4x2uig__spotlight-media {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: var(--sai-im4x2uig-spotlight-fit, contain);
  border-radius: 0;
}

/* ── Fade transition ── */

.sai-im4x2uig--fade .sai-im4x2uig__spotlight-media {
  animation: sai-im4x2uig-fade-in var(--sai-duration-3) var(--sai-ease-out-1);
}

@keyframes sai-im4x2uig-fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* ── Navigation chevrons ── */

.sai-im4x2uig__nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 40%, transparent));
  color: var(--sai-color-bg);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--sai-shadow-2);
  transition: background var(--sai-duration-2) var(--sai-ease-out-1), opacity var(--sai-duration-2)
    var(--sai-ease-out-1);
  opacity: 0;
}

.sai-im4x2uig__spotlight-wrap:hover .sai-im4x2uig__nav,
.sai-im4x2uig__mobile-spotlight-wrap:hover .sai-im4x2uig__nav,
.sai-im4x2uig__mobile-spotlight-wrap .sai-im4x2uig__nav {
  opacity: 1;
}

@media (min-width: 768px) {
  .sai-im4x2uig__spotlight-wrap:not(:hover) .sai-im4x2uig__nav {
    opacity: 0;
  }
}

.sai-im4x2uig__nav:hover {
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 55%, transparent));
}

.sai-im4x2uig__nav--prev {
  left: var(--sai-size-3);
}

.sai-im4x2uig__nav--next {
  right: var(--sai-size-3);
}

/* ── Mobile layout ── */

.sai-im4x2uig__mobile {
  display: block;
}

.sai-im4x2uig__mobile-spotlight-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 0;
  background: var(--sai-color-bg);
  touch-action: pan-y pinch-zoom;
}

.sai-im4x2uig__mobile-track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.sai-im4x2uig__mobile-track::-webkit-scrollbar {
  display: none;
}

.sai-im4x2uig__mobile-slide {
  flex: 0 0 100%;
  scroll-snap-align: center;
  aspect-ratio: 1 / 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

@media (min-width: 768px) {
  .sai-im4x2uig__mobile {
    display: none;
  }
}

/* ── Zoom trigger (magnification glass) ── */

.sai-im4x2uig__zoom-trigger {
  position: absolute;
  bottom: var(--sai-size-3);
  left: var(--sai-size-3);
  z-index: 2;
  width: 36px;
  height: 36px;
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  color: var(--sai-color-fg);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background var(--sai-duration-2) var(--sai-ease-out-1);
}

.sai-im4x2uig__zoom-trigger:hover {
  background: rgba(255, 255, 255, 1);
}

/* ── Carousel dots ── */

.sai-im4x2uig__dots {
  display: flex;
  justify-content: center;
  gap: var(--sai-size-2);
  padding: var(--sai-size-3) 0;
}

.sai-im4x2uig__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: none;
  padding: 0;
  background: rgba(0, 0, 0, 0.2);
  cursor: pointer;
  transition: background var(--sai-duration-2) var(--sai-ease-out-1), transform
    var(--sai-duration-2) var(--sai-ease-out-1);
}

.sai-im4x2uig__dot:hover {
  background: rgba(0, 0, 0, 0.4);
}

.sai-im4x2uig__dot--active {
  background: var(--sai-color-accent, rgba(0, 0, 0, 0.8));
  transform: scale(1.25);
}

/* ── Mobile thumbnail strip (alternative to dots; mobile_nav = thumbnails) ──
   Lives inside .sai-im4x2uig__mobile, which is display:none ≥768px, so the
   strip is mobile-only without its own breakpoint. Thumbs reuse .__thumb
   (fixed size + flex-shrink:0), so only the horizontal scroll container is new. */

.sai-im4x2uig__mobile-thumbs {
  display: flex;
  flex-direction: row;
  gap: var(--sai-size-2);
  padding: var(--sai-size-3);
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}

.sai-im4x2uig__mobile-thumbs::-webkit-scrollbar {
  display: none;
}

/* ── Stepper indicator ── */

.sai-im4x2uig__stepper {
  text-align: center;
  padding: var(--sai-size-3) 0;
  font-family: var(--sai-font-body);
  font-size: 0.8125rem;
  color: var(--sai-color-fg);
  opacity: 0.6;
}

/* ── Lightbox ── */

.sai-im4x2uig__lightbox {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  margin: 0;
  padding: 0;
  border: none;
  background: var(--sai-im4x2uig-overlay-color, #000000e6);
  z-index: 9999;
}

.sai-im4x2uig__lightbox::backdrop {
  background: rgba(0, 0, 0, 0.5);
}

.sai-im4x2uig__lightbox[open] {
  display: flex;
  flex-direction: column;
}

/* ── Lightbox header ── */

.sai-im4x2uig__lightbox-header {
  display: flex;
  justify-content: flex-end;
  padding: 12px 16px;
  flex-shrink: 0;
}

.sai-im4x2uig__lightbox-close {
  width: 36px;
  height: 36px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sai-im4x2uig__lightbox-close:hover {
  background: rgba(255, 255, 255, 0.25);
}

/* ── Lightbox spotlight ── */

.sai-im4x2uig__lightbox-spotlight {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sai-im4x2uig__lightbox-video-wrap {
  position: relative;
  display: inline-flex;
}

.sai-im4x2uig__lightbox-spotlight img,
.sai-im4x2uig__lightbox-spotlight video,
.sai-im4x2uig__lightbox-video-wrap {
  transition: transform 0.15s ease-out;
  transform-origin: center center;
}

.sai-im4x2uig__lightbox-main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  min-height: 0;
  padding: 0 60px;
}

.sai-im4x2uig__lightbox-spotlight {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sai-im4x2uig__lightbox-spotlight img,
.sai-im4x2uig__lightbox-spotlight video,
.sai-im4x2uig__lightbox-video-wrap {
  max-width: 100%;
  max-height: 100%;
  object-fit: var(--sai-im4x2uig-lightbox-fit, contain);
}

/* ── Lightbox nav ── */

.sai-im4x2uig__lightbox-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sai-im4x2uig__lightbox-nav:hover {
  background: rgba(255, 255, 255, 0.25);
}

.sai-im4x2uig__lightbox-nav--prev {
  left: 16px;
}

.sai-im4x2uig__lightbox-nav--next {
  right: 16px;
}

/* ── Lightbox thumbnails ── */

.sai-im4x2uig__lightbox-thumbs {
  display: flex;
  /* `safe center` centres the strip when the thumbs fit, but falls back to
     start-aligned once they overflow — without it, `center` + overflow-x
     clips the first thumb off the left edge (unreachable by scroll) on
     mobile / many-image galleries. */
  justify-content: safe center;
  gap: 8px;
  padding: 12px 16px;
  overflow-x: auto;
  scrollbar-width: none;
  flex-shrink: 0;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.sai-im4x2uig__lightbox-thumbs::-webkit-scrollbar {
  display: none;
}

.sai-im4x2uig__lightbox-thumb {
  flex-shrink: 0;
  width: 56px;
  height: 56px;
  padding: 0;
  border: 2px solid transparent;
  border-radius: 6px;
  background: transparent;
  cursor: pointer;
  overflow: hidden;
  opacity: 0.5;
  transition: border-color 0.2s ease, opacity 0.2s ease;
}

.sai-im4x2uig__lightbox-thumb:hover {
  opacity: 0.8;
}

.sai-im4x2uig__lightbox-thumb--active {
  border-color: #fff;
  opacity: 1;
}

.sai-im4x2uig__lightbox-thumb img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ───── Native fallback: no Spectrum metafields yet — show native product.media ───── */
.sai-im4x2uig__native {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.sai-im4x2uig__native-item {
  width: 100%;
}
.sai-im4x2uig__native-media,
.sai-im4x2uig__native-item img,
.sai-im4x2uig__native-item video,
.sai-im4x2uig__native-item model-viewer,
.sai-im4x2uig__native-item iframe {
  display: block;
  width: 100%;
  height: auto;
}
{% endstylesheet %}

{%- assign asset_list = product.metafields.spectrum.media_assets.value -%}

{%- assign selected_variant = product.selected_or_first_available_variant -%}
{%- assign variant_slots = selected_variant.metafields.spectrum.media_slots.value -%}
{%- assign product_slots = product.metafields.spectrum.media_slots.value -%}
{%- assign slot = nil -%}
{%- if variant_slots != blank and variant_slots['gallery'] != blank -%}
  {%- assign slot = variant_slots['gallery'] -%}
{%- elsif product_slots != blank and product_slots['gallery'] != blank -%}
  {%- assign slot = product_slots['gallery'] -%}
{%- endif -%}

{%- assign slot_variant = nil -%}
{%- if slot != blank -%}
  {%- for candidate in slot.variants -%}
    {%- if candidate.targeting == blank -%}
      {%- assign slot_variant = candidate -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign asset_handles = slot_variant.assets -%}
{%- assign asset_count = 0 -%}
{%- if asset_handles != blank -%}
  {%- assign asset_count = asset_handles.size -%}
{%- endif -%}

{%- comment -%} ── Resolve props from variant.content with defaults ── {%- endcomment -%}
{%- assign _c = variant.content -%}
{%- if _c.autoplay == nil -%}{%- assign autoplay = false -%}{%- else -%}{%- assign autoplay = _c.autoplay -%}{%- endif -%}
{%- if _c.autoplay_interval == nil -%}{%- assign autoplay_interval = 5 -%}{%- else -%}{%- assign autoplay_interval = _c.autoplay_interval -%}{%- endif -%}
{%- if _c.swipe_enabled == nil -%}{%- assign swipe_enabled = true -%}{%- else -%}{%- assign swipe_enabled = _c.swipe_enabled -%}{%- endif -%}
{%- if _c.autoplay_video == nil -%}{%- assign autoplay_video = true -%}{%- else -%}{%- assign autoplay_video = _c.autoplay_video -%}{%- endif -%}
{%- if _c.show_play_pause == nil -%}{%- assign show_play_pause = true -%}{%- else -%}{%- assign show_play_pause = _c.show_play_pause -%}{%- endif -%}
{%- if _c.show_thumbnails == nil -%}{%- assign show_thumbnails = true -%}{%- else -%}{%- assign show_thumbnails = _c.show_thumbnails -%}{%- endif -%}
{%- if _c.show_zoom_controls == nil -%}{%- assign show_zoom_controls = true -%}{%- else -%}{%- assign show_zoom_controls = _c.show_zoom_controls -%}{%- endif -%}
{%- if _c.pinch_to_zoom == nil -%}{%- assign pinch_to_zoom = true -%}{%- else -%}{%- assign pinch_to_zoom = _c.pinch_to_zoom -%}{%- endif -%}
{%- if _c.spotlight_object_fit == nil or _c.spotlight_object_fit == blank -%}{%- assign spotlight_object_fit = 'contain' -%}{%- else -%}{%- assign spotlight_object_fit = _c.spotlight_object_fit -%}{%- endif -%}
{%- if _c.thumbnail_object_fit == nil or _c.thumbnail_object_fit == blank -%}{%- assign thumbnail_object_fit = 'cover' -%}{%- else -%}{%- assign thumbnail_object_fit = _c.thumbnail_object_fit -%}{%- endif -%}
{%- if _c.lightbox_object_fit == nil or _c.lightbox_object_fit == blank -%}{%- assign lightbox_object_fit = 'contain' -%}{%- else -%}{%- assign lightbox_object_fit = _c.lightbox_object_fit -%}{%- endif -%}
{%- if _c.overlay_color == nil or _c.overlay_color == blank -%}{%- assign overlay_color = '#000000e6' -%}{%- else -%}{%- assign overlay_color = _c.overlay_color -%}{%- endif -%}
{%- if _c.active_thumb_border_color == nil or _c.active_thumb_border_color == blank -%}{%- assign active_thumb_border_color = '#000000' -%}{%- else -%}{%- assign active_thumb_border_color = _c.active_thumb_border_color -%}{%- endif -%}
{%- if _c.thumbnails_visible == nil -%}{%- assign thumbnails_visible = 20 -%}{%- else -%}{%- assign thumbnails_visible = _c.thumbnails_visible -%}{%- endif -%}
{%- if _c.filter_cta_label == nil or _c.filter_cta_label == blank -%}{%- assign filter_cta_label = 'Select model' -%}{%- else -%}{%- assign filter_cta_label = _c.filter_cta_label -%}{%- endif -%}
{%- if _c.mobile_nav == nil or _c.mobile_nav == blank -%}{%- assign mobile_nav = 'dots' -%}{%- else -%}{%- assign mobile_nav = _c.mobile_nav -%}{%- endif -%}
{%- comment -%} Default-to-safe: any unexpected value falls back to dots (the original behaviour). {%- endcomment -%}
{%- if mobile_nav != 'dots' and mobile_nav != 'thumbnails' -%}{%- assign mobile_nav = 'dots' -%}{%- endif -%}

{%- if asset_count > 0 -%}
<script src="{{ 'sai-snippet-im4x2uig.js' | asset_url }}" async></script>
<sai-im4x2uig
  class="sai-im4x2uig"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ selected_variant.id }}"
  data-asset-count="{{ asset_count }}"
  data-autoplay="{{ autoplay }}"
  data-autoplay-interval="{{ autoplay_interval }}"
  data-swipe-enabled="{{ swipe_enabled }}"
  data-autoplay-video="{{ autoplay_video }}"
  data-show-play-pause="{{ show_play_pause }}"
  data-show-lightbox-thumbs="{{ show_thumbnails }}"
  data-show-zoom-controls="{{ show_zoom_controls }}"
  data-pinch-to-zoom="{{ pinch_to_zoom }}"
  data-spotlight-object-fit="{{ spotlight_object_fit }}"
  data-thumbnail-object-fit="{{ thumbnail_object_fit }}"
  data-lightbox-object-fit="{{ lightbox_object_fit }}"
>
  <style>
    sai-im4x2uig {
      --sai-im4x2uig-spotlight-fit: {{ spotlight_object_fit }};
      --sai-im4x2uig-thumb-fit: {{ thumbnail_object_fit }};
      --sai-im4x2uig-lightbox-fit: {{ lightbox_object_fit }};
      --sai-im4x2uig-overlay-color: {{ overlay_color }};
      --sai-im4x2uig-active-thumb-border: {{ active_thumb_border_color }};
      --sai-im4x2uig-thumbs-visible: {{ thumbnails_visible }};
    }
  </style>
  {%- comment -%} ── Filter overlay + panel (populated by JS from filterTags) ── {%- endcomment -%}
  <dialog class="sai-im4x2uig__filter-dialog" aria-label="Filter images">
    <div class="sai-im4x2uig__filter-panel">
      <div class="sai-im4x2uig__filter-panel-header">
        <span class="sai-im4x2uig__filter-panel-title">Filters</span>
        <button class="sai-im4x2uig__filter-panel-clear" type="button" data-action="clear-filters" style="display:none">Clear all</button>
      </div>
      <div class="sai-im4x2uig__filter-tabs"></div>
      <div class="sai-im4x2uig__filter-panel-body">
        <div class="sai-im4x2uig__filters"></div>
      </div>
      <div class="sai-im4x2uig__filter-panel-footer">
        <button class="sai-im4x2uig__filter-panel-cancel" type="button" data-action="close-filters">Cancel</button>
        <button class="sai-im4x2uig__filter-panel-apply" type="button" data-action="apply-filters">Apply</button>
      </div>
    </div>
  </dialog>

  {%- comment -%} ── Empty state ── {%- endcomment -%}
  <div class="sai-im4x2uig__empty">No images match the selected filters.</div>

  {%- comment -%} ── Desktop layout: thumbs + spotlight ── {%- endcomment -%}
  <div class="sai-im4x2uig__desktop">
    <div class="sai-im4x2uig__thumbs">
      {%- for handle in asset_handles -%}
        {%- assign thumb_asset = nil -%}
        {%- for asset_ref in asset_list -%}
          {%- if asset_ref.system.handle == handle -%}
            {%- assign thumb_asset = asset_ref -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if thumb_asset != blank -%}
          <button
            class="sai-im4x2uig__thumb{% if forloop.first %} sai-im4x2uig__thumb--active{% endif %}"
            type="button"
            data-index="{{ forloop.index0 }}"
            data-handle="{{ handle }}"
            aria-label="View image {{ forloop.index }}"
          >
            {%- if thumb_asset.asset_type == 'video' -%}
              {%- assign thumb_vid_file = thumb_asset.file.value | default: thumb_asset.file -%}
              {%- if thumb_vid_file.preview_image != blank -%}
                <img
                  class="sai-im4x2uig__thumb-media"
                  src="{{ thumb_vid_file.preview_image | image_url: width: 120 }}"
                  alt="{{ thumb_asset.alt | escape }}"
                  loading="lazy"
                />
              {%- endif -%}
              <span class="sai-im4x2uig__thumb-play" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </span>
            {%- else -%}
              <img
                class="sai-im4x2uig__thumb-media"
                src="{{ thumb_asset.file | image_url: width: 120 }}"
                alt="{{ thumb_asset.alt | escape }}"
                loading="lazy"
              />
            {%- endif -%}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="sai-im4x2uig__spotlight-wrap">
      {%- assign first_asset = nil -%}
      {%- for asset_ref in asset_list -%}
        {%- if asset_ref.system.handle == asset_handles[0] -%}
          {%- assign first_asset = asset_ref -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      <div class="sai-im4x2uig__spotlight" data-index="0">
        {%- if first_asset != blank -%}
          {%- if first_asset.asset_type == 'video' -%}
            {%- assign vid_file = first_asset.file.value | default: first_asset.file -%}
            {%- assign vid_url = '' -%}
            {%- if vid_file.sources != blank -%}
              {%- for source in vid_file.sources -%}
                {%- if source.format == 'mp4' and vid_url == '' -%}
                  {%- assign vid_url = source.url -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if vid_url == '' -%}
                {%- assign vid_url = vid_file.sources.first.url -%}
              {%- endif -%}
            {%- elsif vid_file.url != blank -%}
              {%- assign vid_url = vid_file.url -%}
            {%- endif -%}
            <video
              class="sai-im4x2uig__spotlight-media"
              src="{{ vid_url }}"
              autoplay muted loop playsinline
              {%- if vid_file.preview_image != blank %} poster="{{ vid_file.preview_image | image_url: width: 1200 }}"{% endif %}
            ></video>
          {%- else -%}
            <img
              class="sai-im4x2uig__spotlight-media"
              src="{{ first_asset.file | image_url: width: 1200 }}"
              alt="{{ first_asset.alt | escape }}"
              width="{{ first_asset.file.width }}"
              height="{{ first_asset.file.height }}"
              loading="eager"
              fetchpriority="high"
            />
          {%- endif -%}
        {%- endif -%}
      </div>

      <button class="sai-im4x2uig__select-model" type="button" data-action="toggle-filters" aria-label="{{ filter_cta_label }}">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <path d="M3 6h18M7 12h10M10 18h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        {{ filter_cta_label }}
      </button>
      <button class="sai-im4x2uig__zoom-trigger" type="button" data-action="open-lightbox" aria-label="Zoom">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
          <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M8 11h6M11 8v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      {%- if asset_count > 1 -%}
        <button class="sai-im4x2uig__nav sai-im4x2uig__nav--prev" type="button" aria-label="Previous image" data-action="prev">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
            <path d="M15 18l-6-7 6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="sai-im4x2uig__nav sai-im4x2uig__nav--next" type="button" aria-label="Next image" data-action="next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
            <path d="M9 18l6-7-6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ── Mobile layout: spotlight + chevrons + dots ── {%- endcomment -%}
  <div class="sai-im4x2uig__mobile">
    <div class="sai-im4x2uig__mobile-spotlight-wrap">
      <div class="sai-im4x2uig__mobile-track">
        {%- for handle in asset_handles -%}
          {%- assign slide_asset = nil -%}
          {%- for asset_ref in asset_list -%}
            {%- if asset_ref.system.handle == handle -%}
              {%- assign slide_asset = asset_ref -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if slide_asset != blank -%}
            <div class="sai-im4x2uig__mobile-slide" data-index="{{ forloop.index0 }}" data-handle="{{ handle }}">
              {%- if slide_asset.asset_type == 'video' -%}
                {%- assign s_vid_file = slide_asset.file.value | default: slide_asset.file -%}
                {%- assign s_vid_url = '' -%}
                {%- if s_vid_file.sources != blank -%}
                  {%- for source in s_vid_file.sources -%}
                    {%- if source.format == 'mp4' and s_vid_url == '' -%}
                      {%- assign s_vid_url = source.url -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if s_vid_url == '' -%}
                    {%- assign s_vid_url = s_vid_file.sources.first.url -%}
                  {%- endif -%}
                {%- elsif s_vid_file.url != blank -%}
                  {%- assign s_vid_url = s_vid_file.url -%}
                {%- endif -%}
                <video
                  class="sai-im4x2uig__spotlight-media"
                  src="{{ s_vid_url }}"
                  autoplay muted loop playsinline
                  {%- if s_vid_file.preview_image != blank %} poster="{{ s_vid_file.preview_image | image_url: width: 800 }}"{% endif %}
                ></video>
              {%- else -%}
                <img
                  class="sai-im4x2uig__spotlight-media"
                  src="{{ slide_asset.file | image_url: width: 800 }}"
                  alt="{{ slide_asset.alt | escape }}"
                  {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
                />
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <button class="sai-im4x2uig__select-model" type="button" data-action="toggle-filters" aria-label="{{ filter_cta_label }}">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <path d="M3 6h18M7 12h10M10 18h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        {{ filter_cta_label }}
      </button>
      <button class="sai-im4x2uig__zoom-trigger" type="button" data-action="open-lightbox" aria-label="Zoom">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
          <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M8 11h6M11 8v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      {%- if asset_count > 1 -%}
        <button class="sai-im4x2uig__nav sai-im4x2uig__nav--prev" type="button" aria-label="Previous image" data-action="prev">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
            <path d="M15 18l-6-7 6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="sai-im4x2uig__nav sai-im4x2uig__nav--next" type="button" aria-label="Next image" data-action="next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
            <path d="M9 18l6-7-6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {%- endif -%}
    </div>

    {%- if asset_count > 1 -%}
      {%- if mobile_nav == 'thumbnails' -%}
        {%- comment -%} Mobile thumbnail strip — reuses the .__thumb button so the JS thumb sync (active class + scroll-into-view + click→goTo) drives it identically to the desktop strip. {%- endcomment -%}
        <div class="sai-im4x2uig__mobile-thumbs">
          {%- for handle in asset_handles -%}
            {%- assign m_thumb_asset = nil -%}
            {%- for asset_ref in asset_list -%}
              {%- if asset_ref.system.handle == handle -%}
                {%- assign m_thumb_asset = asset_ref -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if m_thumb_asset != blank -%}
              <button
                class="sai-im4x2uig__thumb{% if forloop.first %} sai-im4x2uig__thumb--active{% endif %}"
                type="button"
                data-index="{{ forloop.index0 }}"
                data-handle="{{ handle }}"
                aria-label="View image {{ forloop.index }}"
              >
                {%- if m_thumb_asset.asset_type == 'video' -%}
                  {%- assign m_thumb_vid_file = m_thumb_asset.file.value | default: m_thumb_asset.file -%}
                  {%- if m_thumb_vid_file.preview_image != blank -%}
                    <img
                      class="sai-im4x2uig__thumb-media"
                      src="{{ m_thumb_vid_file.preview_image | image_url: width: 120 }}"
                      alt="{{ m_thumb_asset.alt | escape }}"
                      loading="lazy"
                    />
                  {%- endif -%}
                  <span class="sai-im4x2uig__thumb-play" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </span>
                {%- else -%}
                  <img
                    class="sai-im4x2uig__thumb-media"
                    src="{{ m_thumb_asset.file | image_url: width: 120 }}"
                    alt="{{ m_thumb_asset.alt | escape }}"
                    loading="lazy"
                  />
                {%- endif -%}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="sai-im4x2uig__dots">
          {%- for handle in asset_handles -%}
            <button
              class="sai-im4x2uig__dot{% if forloop.first %} sai-im4x2uig__dot--active{% endif %}"
              type="button"
              data-index="{{ forloop.index0 }}"
              aria-label="Go to image {{ forloop.index }}"
            ></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- comment -%} ── Lightbox: spotlight + thumbnail strip ── {%- endcomment -%}
  <dialog class="sai-im4x2uig__lightbox" aria-modal="true" aria-label="Product gallery">
    <div class="sai-im4x2uig__lightbox-header">
      <button class="sai-im4x2uig__lightbox-close" type="button" data-action="close-lightbox" aria-label="Close gallery">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="sai-im4x2uig__lightbox-main">
      <div class="sai-im4x2uig__lightbox-spotlight"></div>
      <button class="sai-im4x2uig__lightbox-nav sai-im4x2uig__lightbox-nav--prev" type="button" data-action="lightbox-prev" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <path d="M15 18l-6-7 6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="sai-im4x2uig__lightbox-nav sai-im4x2uig__lightbox-nav--next" type="button" data-action="lightbox-next" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <path d="M9 18l6-7-6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
    <div class="sai-im4x2uig__lightbox-thumbs"></div>
  </dialog>
</sai-im4x2uig>

{%- comment -%}
  Bespoke pool — pre-loads all assets + variant slots.
  O(n) handle lookup: JS builds a Map from this, no nested iteration.
{%- endcomment -%}
<script type="application/json" data-spectrum-snippet-pool>
{
  "assets": {
    {%- assign first_asset_emitted = false -%}
    {%- for asset_ref in asset_list -%}
      {%- assign a_handle = asset_ref.system.handle -%}
      {%- assign a_type = asset_ref.asset_type | default: 'image' -%}
      {%- assign a_url = '' -%}
      {%- assign a_width = 0 -%}
      {%- assign a_height = 0 -%}
      {%- assign a_thumb = '' -%}

      {%- if a_type == 'video' -%}
        {%- assign a_file = asset_ref.file.value | default: asset_ref.file -%}
        {%- if a_file.sources != blank -%}
          {%- for source in a_file.sources -%}
            {%- if source.format == 'mp4' and a_url == '' -%}
              {%- assign a_url = source.url -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if a_url == '' -%}
            {%- assign a_url = a_file.sources.first.url -%}
          {%- endif -%}
        {%- elsif a_file.url != blank -%}
          {%- assign a_url = a_file.url -%}
        {%- endif -%}
        {%- if a_file.preview_image != blank -%}
          {%- assign a_thumb = a_file.preview_image | image_url: width: 120 -%}
        {%- elsif asset_ref.file.preview_image != blank -%}
          {%- assign a_thumb = asset_ref.file.preview_image | image_url: width: 120 -%}
        {%- endif -%}
      {%- else -%}
        {%- assign a_url = asset_ref.file | image_url: width: 1200 -%}
        {%- assign a_thumb = asset_ref.file | image_url: width: 120 -%}
        {%- assign a_width = asset_ref.file.width -%}
        {%- assign a_height = asset_ref.file.height -%}
      {%- endif -%}

      {%- unless first_asset_emitted -%}{%- assign first_asset_emitted = true -%}{%- else -%},{%- endunless -%}
      {{ a_handle | json }}: {
        "id": {{ asset_ref.asset_id | json }},
        "type": {{ a_type | json }},
        "url": {{ a_url | json }},
        "thumb": {{ a_thumb | json }},
        "alt": {{ asset_ref.alt | default: '' | json }},
        "tags": {
          {%- assign a_tags = asset_ref.tags.value -%}
          {%- if a_tags != blank -%}
            {%- for pair in a_tags -%}
              {%- unless forloop.first -%},{%- endunless -%}
              {%- if pair[1].value != blank -%}
                {{ pair[0] | json }}: {{ pair[1].value | json }}
              {%- else -%}
                {{ pair[0] | json }}: {{ pair[1] | json }}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        },
        "width": {{ a_width | json }},
        "height": {{ a_height | json }}
      }
    {%- endfor -%}
  },
  "productSlots": {
    {%- if product_slots != blank -%}
      {%- for pair in product_slots -%}
        {%- unless forloop.first -%},{%- endunless -%}
        {{ pair[0] | json }}: {
          "filterTags": {
            {%- for ft in pair[1].filterTags -%}
              {%- unless forloop.first -%},{%- endunless -%}
              {{ ft[0] | json }}: {{ ft[1] | json }}
            {%- endfor -%}
          },
          "variants": {{ pair[1].variants | json }}
        }
      {%- endfor -%}
    {%- endif -%}
  },
  "variantSlots": {
    {%- assign first_vs = true -%}
    {%- for v in product.variants -%}
      {%- assign v_slots = v.metafields.spectrum.media_slots.value -%}
      {%- if v_slots != blank -%}
        {%- unless first_vs -%},{%- endunless -%}
        {%- assign first_vs = false -%}
        {{ v.id | append: '' | json }}: {
          {%- for vpair in v_slots -%}
            {%- unless forloop.first -%},{%- endunless -%}
            {{ vpair[0] | json }}: {
              "filterTags": {
                {%- for vft in vpair[1].filterTags -%}
                  {%- unless forloop.first -%},{%- endunless -%}
                  {{ vft[0] | json }}: {{ vft[1] | json }}
                {%- endfor -%}
              },
              "variants": {{ vpair[1].variants | json }}
            }
          {%- endfor -%}
        }
      {%- endif -%}
    {%- endfor -%}
  },
  "displayConfigImages": {
    {%- assign first_dci = true -%}
    {%- for asset_ref in asset_list -%}
      {%- assign dca_list = asset_ref.display_config_assets.value -%}
      {%- if dca_list != blank -%}
        {%- for dca_media in dca_list -%}
          {%- unless first_dci -%},{%- endunless -%}
          {%- assign first_dci = false -%}
          {%- capture _dci_gid -%}gid://shopify/MediaImage/{{ dca_media.id }}{%- endcapture -%}
          {{ _dci_gid | json }}: {{ dca_media | image_url: width: 200 | json }}
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}
  }
}
</script>
{%- else -%}
  {%- comment -%}
    Native fallback — the Spectrum gallery metafields are absent or empty (a product still mirroring,
    or one whose only media Spectrum cannot faithfully mirror yet). Render the native product.media so
    the PDP is never blank. Self-contained: no web component, no JS, so it renders whether or not the
    mirror has run, and shows whatever Shopify has natively (including 3D / external video).
  {%- endcomment -%}
  {%- if product.media.size > 0 -%}
    <div class="sai-im4x2uig__native">
      {%- for media in product.media -%}
        <div class="sai-im4x2uig__native-item">
          {%- if media.media_type == 'image' -%}
            <img
              class="sai-im4x2uig__native-media"
              src="{{ media.preview_image | image_url: width: 1200 }}"
              alt="{{ media.alt | escape }}"
              width="{{ media.preview_image.width }}"
              height="{{ media.preview_image.height }}"
              {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
            />
          {%- else -%}
            {{ media | media_tag }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
{%- endif -%}
