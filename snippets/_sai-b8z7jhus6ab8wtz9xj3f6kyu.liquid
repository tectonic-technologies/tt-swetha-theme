{%- endunless -%}

{%- assign sai_fbt = sai_resource.metafields.custom.fbt_products.value -%}

{%- if sai_resource and sai_fbt and sai_fbt.size > 0 -%}
  <div data-spectrum-instance-id="b8z7jhus6ab8wtz9xj3f6kyu"
       data-spectrum-snippet-id="l2dcg7yd"
       data-spectrum-resource-id="{{ sai_resource.id }}"
       data-spectrum-lq-snippet="mut-b8z7jhus6ab8wtz9xj3f6kyu"
       data-spectrum-experience="_system-native-196398907552"
       data-spectrum-feature-slug="fbt">
    {% render '_sai-snippet-l2dcg7yd' %}
  </div>
{%- elsif sai_resource -%}
  <!-- SAI:WRAPPER:NO_FBT_PRODUCTS product={{ sai_resource.handle }} -->
{%- endif -%}