  snippet body already reads that metafield, so we just render it with the
  product in scope.
{%- endcomment -%}

{%- if sai_state != 'draft' and sai_state != 'live' -%}
  {%- assign sai_state = 'live' -%}
{%- endif -%}

{%- assign sai_resource = nil -%}
{%- if product -%}
