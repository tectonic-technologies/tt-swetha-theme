{% doc %}
  Frequently Bought Together — Individual ATC variant.

  Renders a stacked list of recommended products as a "You will also love!"
  cross-sell module. Each card has its own Add To Cart button — no bundle
  selection, no checkboxes, no aggregated total. Reads the same slot
  envelope as the FBT bundle widget (pb3tmxq9) so the same playbook output
  drives both surfaces.

  @param entry              {SlotEnvelopeEntry} Resolved default entry from
                                                spectrum.recommendations_fbt_
                                                <draft|live>;
                                                `entry.content.recommendations`
                                                is the array of product handles.
  @param variant            {Metaobject}        Default variant; `.content`
                                                carries merchant-edited props.
  @param mo                 {Metaobject}        spectrum_snippet_instance drop.
  @param mutation_handle    {string}            Consumed by the wrapper's outer div.
  @param experience_handle  {string}            Consumed by the wrapper's outer div.
{% enddoc %}

{%- comment -%}
  Trust boundary: every text prop is run through `| escape` so a merchant who
  pastes markup into a text field can't break the page layout.

  Empty / nil `entry.content.recommendations` collapses the whole widget —
  no script tag emitted, no host element rendered.
{%- endcomment -%}

{% stylesheet %}
/* =============================================================================
 * FBT Individual ATC (fbtatc4z) — stacked recommendation cards with per-card
 * Add To Cart buttons.
 *
 * Author selectors stay at specificity (0,1,0) so per-instance baked rules
 * (anchored on [data-spectrum-instance-id][data-spectrum-variant-id]) always
 * win the cascade. Color tokens use --sai-fbtatc4z-* custom properties so
 * the Studio style panel can override them.
 * ============================================================================= */

/* The quickshop overlay is appended to document.body (escapes the snippet
   element's stacking context so the modal can sit above PDP chrome), so
   the custom properties must be declared on BOTH selectors — otherwise the
   panel inherits no value and renders transparent. */
.sai-fbtatc4z,
.sai-fbtatc4z__quickshop {
  --sai-fbtatc4z-card-bg: #ffffff;
  --sai-fbtatc4z-card-border: #eef0f3;
  --sai-fbtatc4z-card-radius: 14px;
  --sai-fbtatc4z-header-bg: #fafbfc;
  --sai-fbtatc4z-header-border: #eef0f3;
  --sai-fbtatc4z-divider: #f1f3f6;
  --sai-fbtatc4z-row-hover: #fafbfc;
  --sai-fbtatc4z-image-size: 4.5rem;
  --sai-fbtatc4z-off-bg: #fee2e2;
  --sai-fbtatc4z-off-fg: #b91c1c;
  --sai-fbtatc4z-price-fg: #dc2626;
  --sai-fbtatc4z-fg: var(--sai-color-fg, #0f172a);
  --sai-fbtatc4z-muted-fg: #64748b;
  --sai-fbtatc4z-cta-bg: #0f172a;
  --sai-fbtatc4z-cta-fg: #ffffff;
  --sai-fbtatc4z-cta-border: #0f172a;
  --sai-fbtatc4z-cta-hover-bg: #1e293b;
  --sai-fbtatc4z-cta-hover-fg: #ffffff;
  --sai-fbtatc4z-cta-disabled-bg: #cbd5e1;
  --sai-fbtatc4z-cta-disabled-fg: #ffffff;
  --sai-fbtatc4z-pill-bg: #ffffff;
  --sai-fbtatc4z-pill-fg: #0f172a;
  --sai-fbtatc4z-pill-selected-bg: #0f172a;
  --sai-fbtatc4z-pill-selected-fg: #ffffff;
  --sai-fbtatc4z-pill-disabled-fg: rgba(0, 0, 0, 0.5);
  --sai-fbtatc4z-modal-overlay-bg: rgba(15, 23, 42, 0.6);
  --sai-fbtatc4z-modal-card-bg: #ffffff;
  --sai-fbtatc4z-done-bg: #0f172a;
  --sai-fbtatc4z-done-fg: #ffffff;
  --sai-fbtatc4z-loader-size: 1rem;
  --sai-fbtatc4z-shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04);
  --sai-fbtatc4z-shadow-md: 0 6px 24px rgba(15, 23, 42, 0.06);
  --sai-fbtatc4z-shadow-row: 0 4px 14px rgba(15, 23, 42, 0.06);
  --sai-fbtatc4z-focus: 0 0 0 2px #ffffff, 0 0 0 4px #0f172a;
}

.sai-fbtatc4z {
  display: block;
  box-sizing: border-box;
  /* Width caps at 32rem OR parent-width-minus-2rem, whichever is smaller.
     Always leaves ≥1rem of horizontal breathing room from the parent's
     edges. `margin-inline: auto` centers the widget when the parent is
     wider than the cap. */
  inline-size: auto;
  min-inline-size: 0;
  max-inline-size: min(32rem, calc(100% - 2rem));
  margin-inline: auto;
  margin-block: var(--sai-size-6);
  font-family: var(--sai-font-body);
  font-size: 1rem;
  line-height: 1.4;
  color: var(--sai-fbtatc4z-fg);
  background: var(--sai-fbtatc4z-card-bg);
  border: 1px solid var(--sai-fbtatc4z-card-border);
  border-radius: var(--sai-fbtatc4z-card-radius);
  /* Soft shadow lifts the widget off the page without competing with the
     PDP's own card chrome — paired with a near-invisible border for
     definition on white-on-white backgrounds. */
  box-shadow: var(--sai-fbtatc4z-shadow-md);
  overflow: hidden;
}

.sai-fbtatc4z *,
.sai-fbtatc4z *::before,
.sai-fbtatc4z *::after {
  box-sizing: border-box;
}

.sai-fbtatc4z__header {
  padding: 1.375rem 1.375rem 1rem;
  background: var(--sai-fbtatc4z-header-bg);
  border-block-end: 1px solid var(--sai-fbtatc4z-header-border);
}

.sai-fbtatc4z__heading {
  margin: 0;
  font-family: var(--sai-font-heading, var(--sai-font-body));
  /* Lighter weight gives a less blocky feel than 700/bold for the
     stacked-cards layout. Style stays upright so merchants who change
     the heading copy aren't stuck with unwanted italics. */
  font-size: 1.0625rem;
  font-weight: 500;
  line-height: 1.3;
  letter-spacing: -0.005em;
  color: var(--sai-fbtatc4z-fg);
}

.sai-fbtatc4z__subtitle {
  margin: 0.375rem 0 0;
  font-size: 0.8125rem;
  font-weight: 400;
  line-height: 1.45;
  letter-spacing: 0.005em;
  color: var(--sai-fbtatc4z-muted-fg);
}

.sai-fbtatc4z__list {
  display: flex;
  flex-direction: column;
  margin: 0;
  padding: 0.375rem 0;
  list-style: none;
}

/* "Product on this page" — inline grey pill above the main product
   card, visually attached to the row below it. The <li> is the layout
   wrapper (margin, alignment); the inner <span> is the visible pill,
   and is what the `sub_header` style node targets so the Studio
   Styling panel can change its background / typography / border /
   spacing. Sits outside the divider chain (`__card + __card`), so it
   doesn't introduce a divider above the main card. */
.sai-fbtatc4z__list-section-header {
  display: flex;
  margin: 0.75rem 1.25rem 0;
  padding: 0;
}

.sai-fbtatc4z__sub-header-pill {
  display: inline-flex;
  align-items: center;
  padding: 0.1875rem 0.625rem;
  font-size: 0.65625rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #334155;
  background: #f1f3f6;
  border-radius: 999px;
  line-height: 1.4;
}

/* Tighten the gap so the pill reads as paired with the first card. */
.sai-fbtatc4z__list-section-header + .sai-fbtatc4z__card {
  padding-block-start: 0.5rem;
}

/* Card: 3-column grid (image | body | CTA). Horizontal padding lives on
   the card so the hairline divider between rows extends edge-to-edge.
   Position-relative so we can place a pseudo-element divider above each
   subsequent card without nudging layout. */
.sai-fbtatc4z__card {
  position: relative;
  display: grid;
  grid-template-columns: var(--sai-fbtatc4z-image-size) 1fr auto;
  align-items: center;
  gap: 0.875rem;
  padding: 0.875rem 1.25rem;
  background: var(--sai-fbtatc4z-card-bg);
  border-radius: 10px;
  transition: background 160ms ease, box-shadow 200ms ease, transform 200ms ease;
}

/* Hairline solid divider drawn as a pseudo-element so the hover lift
   (transform + shadow) doesn't visually overlap the divider line. */
.sai-fbtatc4z__card + .sai-fbtatc4z__card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 1.25rem;
  right: 1.25rem;
  height: 1px;
  background: var(--sai-fbtatc4z-divider);
  pointer-events: none;
  transition: opacity 160ms ease;
}

.sai-fbtatc4z__card:hover {
  background: var(--sai-fbtatc4z-row-hover);
  box-shadow: var(--sai-fbtatc4z-shadow-row);
  transform: translateY(-1px);
}

/* Hide the divider above (and below) a hovered row so the lift reads clean. */
.sai-fbtatc4z__card:hover::before,
.sai-fbtatc4z__card:hover + .sai-fbtatc4z__card::before {
  opacity: 0;
}

/* ── Mobile / narrow column ────────────────────────────────────────────
   Keep the image | body | +ADD row at every size — just shrink the fixed
   columns so the body still has readable width. The +ADD CTA loses its
   min-inline-size so it can tighten to label width on a narrow viewport. */
@media (max-width: 540px) {
  .sai-fbtatc4z {
    --sai-fbtatc4z-image-size: 4rem;
  }

  .sai-fbtatc4z__card {
    gap: var(--sai-size-3);
    padding: var(--sai-size-4);
  }

  .sai-fbtatc4z__cta {
    min-inline-size: 0;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
  }

  .sai-fbtatc4z__variant-trigger {
    font-size: 0.8125rem;
    padding: 0.4375rem 0.75rem;
  }
}

/* Very small phones — tighten the header band, drop title size, and let
   the +ADD button shrink even further so the row stays single-line. */
@media (max-width: 380px) {
  .sai-fbtatc4z {
    --sai-fbtatc4z-image-size: 3.5rem;
  }

  .sai-fbtatc4z__header {
    padding: var(--sai-size-3) var(--sai-size-4);
  }

  .sai-fbtatc4z__title {
    font-size: 0.9375rem;
  }

  .sai-fbtatc4z__cta {
    padding: 0.5rem 0.5rem;
    font-size: 0.75rem;
  }
}

.sai-fbtatc4z__media {
  display: block;
  inline-size: var(--sai-fbtatc4z-image-size);
  /* block-size: auto is the default, but stating it here makes the
     contract explicit: the box's height is driven by the inline
     `aspect-ratio` style emitted from the image_aspect_ratio prop.
     Setting a fixed block-size here would override aspect-ratio and
     trap the box at a square regardless of the prop. */
  block-size: auto;
  border-radius: 10px;
  overflow: hidden;
  /* Subtle warm gradient when no product image is loaded. Inner ring
     gives a hairline border on top of any image without affecting layout. */
  background: linear-gradient(180deg, #f4f6fb 0%, #eaeef5 100%);
  box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.04);
  text-decoration: none;
}

.sai-fbtatc4z__image {
  display: block;
  inline-size: 100%;
  block-size: 100%;
  object-fit: cover;
}

.sai-fbtatc4z__body {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  /* Grid item default min-size is min-content — without this the body
     column won't shrink below its longest word, and a card with a long
     product title would force the whole widget wider than its parent. */
  min-inline-size: 0;
}

.sai-fbtatc4z__title {
  margin: 0;
  font-size: 0.875rem;
  font-weight: 600;
  line-height: 1.35;
  letter-spacing: -0.005em;
  color: var(--sai-fbtatc4z-fg);
  text-decoration: none;
  overflow-wrap: anywhere;
  word-break: break-word;
  /* 2-line clamp keeps long titles from blowing out the row height. */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.sai-fbtatc4z__title:hover {
  text-decoration: underline;
}

.sai-fbtatc4z__price-row {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0.4375rem;
  margin-block-start: 0.25rem;
  font-size: 0.875rem;
}

.sai-fbtatc4z__price {
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--sai-fbtatc4z-price-fg);
  font-variant-numeric: tabular-nums;
}

.sai-fbtatc4z__compare {
  font-size: 0.8125rem;
  color: var(--sai-fbtatc4z-muted-fg);
  text-decoration: line-through;
  font-variant-numeric: tabular-nums;
}

.sai-fbtatc4z__off-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.1875rem 0.4375rem;
  background: var(--sai-fbtatc4z-off-bg);
  color: var(--sai-fbtatc4z-off-fg);
  font-size: 0.6875rem;
  font-weight: 600;
  line-height: 1;
  letter-spacing: 0.02em;
  border-radius: 4px;
}

/* Author `display` rules above override the UA `[hidden]` rule (which is
   only at user-agent specificity), so `<span hidden>` would still render
   an empty green pill / strike-through span. Re-assert `display: none`
   at author specificity for the badge + compare placeholders that the
   variant-picker toggles. */
.sai-fbtatc4z__off-badge[hidden],
.sai-fbtatc4z__compare[hidden] {
  display: none;
}

.sai-fbtatc4z__cta {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-inline-size: 5.25rem;
  min-block-size: 2.375rem;
  padding: 0.5625rem 0.9375rem;
  background: var(--sai-fbtatc4z-cta-bg);
  color: var(--sai-fbtatc4z-cta-fg);
  border: 1px solid var(--sai-fbtatc4z-cta-border);
  border-radius: 8px;
  font-family: inherit;
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  cursor: pointer;
  transition: background 160ms ease, color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
}

.sai-fbtatc4z__cta:hover:not([disabled]):not([data-state="added"]) {
  background: var(--sai-fbtatc4z-cta-hover-bg);
  color: var(--sai-fbtatc4z-cta-hover-fg);
  transform: translateY(-1px);
  box-shadow: var(--sai-fbtatc4z-shadow-sm);
}

.sai-fbtatc4z__cta:focus-visible {
  outline: none;
  box-shadow: var(--sai-fbtatc4z-focus);
}

.sai-fbtatc4z__cta[disabled],
.sai-fbtatc4z__cta[aria-disabled="true"] {
  background: var(--sai-fbtatc4z-cta-disabled-bg);
  color: var(--sai-fbtatc4z-cta-disabled-fg);
  border-color: var(--sai-fbtatc4z-cta-disabled-bg);
  cursor: not-allowed;
}

.sai-fbtatc4z__cta[data-state="added"] {
  background: #0f9d58;
  border-color: #0f9d58;
}

.sai-fbtatc4z__cta[data-loading="true"] [data-fbtatc-cta-label] {
  visibility: hidden;
}

.sai-fbtatc4z__loader {
  position: absolute;
  inset: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.sai-fbtatc4z__loader[hidden] {
  display: none;
}

.sai-fbtatc4z__spinner {
  inline-size: var(--sai-fbtatc4z-loader-size);
  block-size: var(--sai-fbtatc4z-loader-size);
  animation: sai-fbtatc4z-spin 0.8s linear infinite;
}

/* Variant trigger pill rendered below the product title in `below_title`
   mode. Click opens the quickshop. Hidden in `on_atc` mode (the +ADD
   button is the picker trigger there). */
.sai-fbtatc4z__variant-trigger {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  align-self: flex-start;
  margin-block-start: 0.5rem;
  padding: 0.3125rem 0.625rem 0.3125rem 0.75rem;
  background: #ffffff;
  color: var(--sai-fbtatc4z-fg);
  border: 1px solid #e2e6ec;
  border-radius: 999px;
  font-family: inherit;
  font-size: 0.75rem;
  font-weight: 500;
  line-height: 1.2;
  cursor: pointer;
  transition: background 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
}

.sai-fbtatc4z__variant-trigger:hover {
  background: #fafbfc;
  border-color: #cbd5e1;
  box-shadow: var(--sai-fbtatc4z-shadow-sm);
}

.sai-fbtatc4z__variant-trigger:focus-visible {
  outline: none;
  border-color: var(--sai-fbtatc4z-fg);
}

.sai-fbtatc4z__variant-chevron {
  inline-size: 0.75rem;
  block-size: 0.75rem;
  flex-shrink: 0;
  opacity: 0.6;
}

.sai-fbtatc4z__error {
  margin: var(--sai-size-3) var(--sai-size-5) var(--sai-size-5);
  padding: 0.5rem 0.75rem;
  background: rgba(210, 66, 7, 0.08);
  color: #b9370a;
  font-size: 0.8125rem;
  border-radius: 6px;
}

.sai-fbtatc4z__error[hidden] {
  display: none;
}

/* ── Mini-PDP / quickshop ─────────────────────────────────────────────
   Triggered when the shopper clicks +ADD on a multi-variant product. Full
   bottom sheet on mobile, centred modal on desktop. The modal IS the
   purchase surface (image + title + price + options + ATC inside) —
   picking a value updates image/price live; clicking ATC inside the
   modal adds the resolved variant and closes. Mirrors the i2m3o6sr
   Shop-the-Look quickshop pattern. */

.sai-fbtatc4z__quickshop {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.45);
  opacity: 0;
  pointer-events: none;
  transition: background-color 0.22s ease, opacity 0.22s ease;
}

.sai-fbtatc4z__quickshop[hidden] { display: none !important; }

.sai-fbtatc4z__quickshop--open {
  background-color: rgba(0, 0, 0, 0.65);
  opacity: 1;
  pointer-events: auto;
}

.sai-fbtatc4z__quickshop-backdrop {
  position: absolute;
  inset: 0;
  background: transparent;
  cursor: pointer;
}

.sai-fbtatc4z__quickshop-panel {
  position: relative;
  z-index: 1;
  inline-size: 100%;
  max-block-size: 88vh;
  background: var(--sai-fbtatc4z-card-bg);
  color: var(--sai-fbtatc4z-fg);
  border-radius: 16px 16px 0 0;
  padding: 20px 20px 22px;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  display: flex;
  flex-direction: column;
  gap: 18px;
  font-family: var(--sai-font-body);
}

.sai-fbtatc4z__quickshop--open .sai-fbtatc4z__quickshop-panel {
  transform: translateY(0);
}

.sai-fbtatc4z__quickshop-close {
  position: absolute;
  top: 12px;
  right: 12px;
  inline-size: 32px;
  block-size: 32px;
  padding: 0;
  background: transparent;
  color: var(--sai-fbtatc4z-fg);
  border: none;
  border-radius: 50%;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  line-height: 1;
}

.sai-fbtatc4z__quickshop-close:hover {
  background: rgba(0, 0, 0, 0.06);
}

.sai-fbtatc4z__quickshop-header {
  display: grid;
  grid-template-columns: 96px 1fr;
  gap: 16px;
  align-items: flex-start;
  padding-inline-end: 36px;
}

.sai-fbtatc4z__quickshop-media {
  inline-size: 96px;
  aspect-ratio: 1 / 1;
  border-radius: 8px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.06);
}

.sai-fbtatc4z__quickshop-image {
  display: block;
  inline-size: 100%;
  block-size: 100%;
  object-fit: cover;
}

.sai-fbtatc4z__quickshop-meta {
  min-inline-size: 0;
  padding-block-start: 4px;
}

.sai-fbtatc4z__quickshop-title {
  display: block;
  font-family: var(--sai-font-heading, var(--sai-font-body));
  font-size: 17px;
  line-height: 1.25;
  font-weight: 700;
  color: var(--sai-fbtatc4z-fg);
  text-decoration: none;
  margin: 0 0 8px;
}

.sai-fbtatc4z__quickshop-title:hover {
  text-decoration: underline;
}

.sai-fbtatc4z__quickshop-price {
  margin: 0;
  font-size: 15px;
  font-weight: 700;
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.sai-fbtatc4z__quickshop-price-compare {
  font-weight: 400;
  text-decoration: line-through;
  opacity: 0.55;
  font-size: 13px;
}

.sai-fbtatc4z__quickshop-price-compare[hidden] {
  display: none;
}

.sai-fbtatc4z__quickshop-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.sai-fbtatc4z__quickshop-group {
  border: 1px solid rgba(0, 0, 0, 0.12);
  border-radius: 10px;
  padding: 12px 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.sai-fbtatc4z__quickshop-group-head {
  display: flex;
  align-items: baseline;
  gap: 6px;
  font-size: 13px;
  line-height: 1.2;
}

.sai-fbtatc4z__quickshop-group-name {
  color: var(--sai-fbtatc4z-fg);
  opacity: 0.55;
}

.sai-fbtatc4z__quickshop-group-selected {
  color: var(--sai-fbtatc4z-fg);
  font-weight: 600;
}

.sai-fbtatc4z__quickshop-group-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.sai-fbtatc4z__quickshop-pill {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  /* center text inside the pill — without justify-content the inner
     <span> packs to flex-start and characters like "S" sit off-center
     on text-only pills. */
  justify-content: center;
  gap: 8px;
  min-inline-size: 64px;
  padding: 10px 14px;
  background: var(--sai-fbtatc4z-card-bg);
  color: var(--sai-fbtatc4z-fg);
  border: 1px solid rgba(0, 0, 0, 0.22);
  border-radius: 999px;
  font-family: var(--sai-font-body);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
}

.sai-fbtatc4z__quickshop-pill:hover {
  border-color: rgba(0, 0, 0, 0.6);
}

.sai-fbtatc4z__quickshop-pill--selected,
.sai-fbtatc4z__quickshop-pill--selected:hover {
  border-color: var(--sai-fbtatc4z-fg);
  border-width: 2px;
  padding: 9px 13px;
}

/* OOS pills get an explicit grey background + strike-through so the
   unavailable state reads regardless of theme contrast. Opacity stays
   moderate so the text is still legible. */
.sai-fbtatc4z__quickshop-pill--oos,
.sai-fbtatc4z__quickshop-pill--oos:hover {
  background: #f1f3f6;
  border-color: rgba(0, 0, 0, 0.12);
  color: rgba(0, 0, 0, 0.5);
  text-decoration: line-through;
  cursor: not-allowed;
}

.sai-fbtatc4z__quickshop-pill-swatch {
  display: inline-block;
  inline-size: 18px;
  block-size: 18px;
  border-radius: 50%;
  background-size: cover;
  background-position: center;
  border: 1px solid rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.sai-fbtatc4z__quickshop-atc {
  inline-size: 100%;
  margin-block-start: 4px;
  padding: 16px 20px;
  background: var(--sai-fbtatc4z-cta-bg);
  color: var(--sai-fbtatc4z-cta-fg);
  border: none;
  border-radius: 4px;
  font-family: var(--sai-font-heading, var(--sai-font-body));
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: opacity 0.15s ease;
}

.sai-fbtatc4z__quickshop-atc:hover:not(:disabled) {
  opacity: 0.88;
}

.sai-fbtatc4z__quickshop-atc:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* Desktop modal — centred panel with constrained width + soft fade-up. */
@media (min-width: 750px) {
  .sai-fbtatc4z__quickshop {
    align-items: center;
  }
  .sai-fbtatc4z__quickshop-panel {
    max-inline-size: 420px;
    max-block-size: 80vh;
    border-radius: 16px;
    transform: translateY(20px);
    opacity: 0;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .sai-fbtatc4z__quickshop--open .sai-fbtatc4z__quickshop-panel {
    transform: translateY(0);
    opacity: 1;
  }
}

@media (prefers-reduced-motion: reduce) {
  .sai-fbtatc4z__quickshop,
  .sai-fbtatc4z__quickshop-panel {
    transition: none;
  }
}

@keyframes sai-fbtatc4z-spin {
  to {
    transform: rotate(360deg);
  }
}

@media (prefers-reduced-motion: reduce) {
  .sai-fbtatc4z__spinner {
    animation-duration: 2s;
  }
}
{% endstylesheet %}

{%- assign content = variant.content -%}
{%- assign heading              = content.heading              | default: '"You will also love!"' | escape -%}
{%- assign subtitle             = content.subtitle             | default: '' | escape -%}
{%- assign cta_label            = content.cta_label            | default: '+ ADD' | escape -%}
{%- assign main_product_label   = content.main_product_label   | default: 'Product on this page' | escape -%}

{%- assign show_main_product = content.show_main_product -%}
{%- if show_main_product == nil -%}{%- assign show_main_product = false -%}{%- endif -%}

{%- assign variant_selector_mode = content.variant_selector_mode -%}
{%- if variant_selector_mode != 'below_title' and variant_selector_mode != 'on_atc' -%}
  {%- assign variant_selector_mode = 'below_title' -%}
{%- endif -%}

{%- assign show_compare_price = content.show_compare_price -%}
{%- if show_compare_price == nil -%}{%- assign show_compare_price = true -%}{%- endif -%}

{%- assign show_discount_badge = content.show_discount_badge -%}
{%- if show_discount_badge == nil -%}{%- assign show_discount_badge = true -%}{%- endif -%}

{%- assign after_add_action = content.after_add_action -%}
{%- if after_add_action != 'stay' and after_add_action != 'redirect-to-cart' and after_add_action != 'redirect-to-checkout' -%}
  {%- assign after_add_action = 'stay' -%}
{%- endif -%}

{%- assign image_aspect_ratio = content.image_aspect_ratio -%}
{%- if image_aspect_ratio != '1:1' and image_aspect_ratio != '4:3' and image_aspect_ratio != '3:4' -%}
  {%- assign image_aspect_ratio = '1:1' -%}
{%- endif -%}
{%- assign aspect_css = '1' -%}
{%- if image_aspect_ratio == '4:3' -%}{%- assign aspect_css = '4 / 3' -%}{%- endif -%}
{%- if image_aspect_ratio == '3:4' -%}{%- assign aspect_css = '3 / 4' -%}{%- endif -%}

{%- assign image_object_fit = content.image_object_fit -%}
{%- if image_object_fit != 'cover' and image_object_fit != 'contain' -%}
  {%- assign image_object_fit = 'cover' -%}
{%- endif -%}

{%- comment -%}
  aspect-ratio drives the *box* shape, so it must be applied to the parent
  `<a class="__media">`. object-fit applies to the <img>. Splitting the two
  inline styles keeps the prop functional regardless of CSS overrides.
{%- endcomment -%}
{%- assign media_style = 'aspect-ratio: ' | append: aspect_css | append: ';' -%}
{%- assign image_style = 'object-fit: ' | append: image_object_fit | append: ';' -%}

{%- assign fbt_handles = entry.content.recommendations -%}

{%- comment -%}
  Pre-pass: count handles that resolve to a real product drop.
  `all_products[h]` returns EmptyDrop (NOT nil) for unknown handles, so the
  safe test is `r == empty`. Skip the main product handle — this widget is
  cross-sell only, never the PDP product itself.
{%- endcomment -%}
{%- assign resolved_count = 0 -%}
{%- if fbt_handles != nil -%}
  {%- for handle in fbt_handles -%}
    {%- if handle == product.handle -%}{%- continue -%}{%- endif -%}
    {%- assign r = all_products[handle] -%}
    {%- unless r == empty -%}
      {%- assign resolved_count = resolved_count | plus: 1 -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%}
  Collapse the whole widget when there's nothing to render — that's BOTH
  no resolved recommendations AND the merchant hasn't opted to include the
  main product card.
{%- endcomment -%}
{%- if resolved_count == 0 and show_main_product != true -%}
  {%- comment -%} nothing to render — skip script tag + host element {%- endcomment -%}
{%- else -%}

<script src="{{ 'sai-snippet-fbtatc4z.js' | asset_url }}" async></script>

<sai-fbtatc4z class="sai-fbtatc4z">
  <div class="sai-fbtatc4z__header">
    <h2 class="sai-fbtatc4z__heading">{{ heading }}</h2>
    {%- if subtitle != '' -%}
      <p class="sai-fbtatc4z__subtitle">{{ subtitle }}</p>
    {%- endif -%}
  </div>

  <ul class="sai-fbtatc4z__list">
    {%- if show_main_product -%}
      <li class="sai-fbtatc4z__list-section-header">
        <span class="sai-fbtatc4z__sub-header-pill">{{ main_product_label }}</span>
      </li>
      {%- assign mv = product.selected_or_first_available_variant -%}
      {%- if show_compare_price and product.compare_at_price and product.compare_at_price > product.price -%}
        {%- assign _m_has_compare = true -%}
        {%- assign _m_off_amount = product.compare_at_price | minus: product.price -%}
        {%- assign _m_off_pct = _m_off_amount | times: 100 | divided_by: product.compare_at_price -%}
      {%- else -%}
        {%- assign _m_has_compare = false -%}
      {%- endif -%}
      <li class="sai-fbtatc4z__card sai-fbtatc4z__card--main" data-product-id="{{ product.id }}">
        <a class="sai-fbtatc4z__media" href="{{ product.url }}" style="{{ media_style }}" tabindex="-1" aria-hidden="true">
          {%- if product.featured_image -%}
            <img
              class="sai-fbtatc4z__image"
              src="{{ product.featured_image | image_url: width: 320 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              style="{{ image_style }}"
              loading="lazy"
            >
          {%- endif -%}
        </a>
        <div class="sai-fbtatc4z__body">
          <a class="sai-fbtatc4z__title" href="{{ product.url }}">{{ product.title }}</a>
          <div class="sai-fbtatc4z__price-row">
            <span class="sai-fbtatc4z__price">{{ product.price | money }}</span>
            {%- if show_compare_price -%}
              <span class="sai-fbtatc4z__compare"{% unless _m_has_compare %} hidden{% endunless %}>
                {%- if _m_has_compare -%}{{ product.compare_at_price | money }}{%- endif -%}
              </span>
            {%- endif -%}
            {%- if show_discount_badge -%}
              <span class="sai-fbtatc4z__off-badge"{% unless _m_has_compare %} hidden{% endunless %}>
                {%- if _m_has_compare -%}{{ _m_off_pct }}% OFF{%- endif -%}
              </span>
            {%- endif -%}
          </div>
          {%- if variant_selector_mode == 'below_title' and product.variants.size > 1 -%}
            <button type="button" class="sai-fbtatc4z__variant-trigger" data-variant-trigger aria-haspopup="dialog">
              <span class="sai-fbtatc4z__variant-label">{{ mv.title }}</span>
              <svg class="sai-fbtatc4z__variant-chevron" viewBox="0 0 14 14" fill="none" focusable="false" aria-hidden="true">
                <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          {%- endif -%}
        </div>
        <button
          type="button"
          class="sai-fbtatc4z__cta"
          data-fbtatc-cta
          data-product-id="{{ product.id }}"
          data-variant-id="{{ mv.id }}"
          {%- unless mv.available %} disabled aria-disabled="true"{%- endunless -%}
        >
          <span data-fbtatc-cta-label>{{ cta_label }}</span>
          <span class="sai-fbtatc4z__loader" data-fbtatc-loader hidden aria-hidden="true">
            <svg class="sai-fbtatc4z__spinner" viewBox="0 0 24 24" fill="none" focusable="false">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-opacity="0.25" stroke-width="3"/>
              <path d="M22 12a10 10 0 0 0-10-10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
      </li>
    {%- endif -%}
    {%- for handle in fbt_handles -%}
      {%- if handle == product.handle -%}{%- continue -%}{%- endif -%}
      {%- assign r = all_products[handle] -%}
      {%- if r == empty -%}{%- continue -%}{%- endif -%}
      {%- assign rv = r.selected_or_first_available_variant -%}
      <li class="sai-fbtatc4z__card" data-product-id="{{ r.id }}">
        <a class="sai-fbtatc4z__media" href="{{ r.url }}" style="{{ media_style }}" tabindex="-1" aria-hidden="true">
          {%- if r.featured_image -%}
            <img
              class="sai-fbtatc4z__image"
              src="{{ r.featured_image | image_url: width: 320 }}"
              alt="{{ r.featured_image.alt | default: r.title | escape }}"
              style="{{ image_style }}"
              loading="lazy"
            >
          {%- endif -%}
        </a>
        <div class="sai-fbtatc4z__body">
          <a class="sai-fbtatc4z__title" href="{{ r.url }}">{{ r.title }}</a>
          {%- comment -%}
            Compare-at + off-badge are always SSR'd (when their respective
            props are enabled) so `_commitModal` can flip their `hidden`
            attribute when the shopper picks a variant whose compare_at_price
            differs from the first-available variant. If we omit the nodes
            here, querySelector returns null in JS and the variant-swap
            silently fails to surface the new discount on non-discount →
            discount transitions.
          {%- endcomment -%}
          {%- if show_compare_price and r.compare_at_price and r.compare_at_price > r.price -%}
            {%- assign _has_compare = true -%}
            {%- assign _off_amount = r.compare_at_price | minus: r.price -%}
            {%- assign _off_pct = _off_amount | times: 100 | divided_by: r.compare_at_price -%}
          {%- else -%}
            {%- assign _has_compare = false -%}
          {%- endif -%}
          <div class="sai-fbtatc4z__price-row">
            <span class="sai-fbtatc4z__price">{{ r.price | money }}</span>
            {%- if show_compare_price -%}
              <span class="sai-fbtatc4z__compare"{% unless _has_compare %} hidden{% endunless %}>
                {%- if _has_compare -%}{{ r.compare_at_price | money }}{%- endif -%}
              </span>
            {%- endif -%}
            {%- if show_discount_badge -%}
              <span class="sai-fbtatc4z__off-badge"{% unless _has_compare %} hidden{% endunless %}>
                {%- if _has_compare -%}{{ _off_pct }}% OFF{%- endif -%}
              </span>
            {%- endif -%}
          </div>
          {%- if variant_selector_mode == 'below_title' and r.variants.size > 1 -%}
            <button type="button" class="sai-fbtatc4z__variant-trigger" data-variant-trigger aria-haspopup="dialog">
              <span class="sai-fbtatc4z__variant-label">{{ rv.title }}</span>
              <svg class="sai-fbtatc4z__variant-chevron" viewBox="0 0 14 14" fill="none" focusable="false" aria-hidden="true">
                <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          {%- endif -%}
        </div>
        <button
          type="button"
          class="sai-fbtatc4z__cta"
          data-fbtatc-cta
          data-product-id="{{ r.id }}"
          data-variant-id="{{ rv.id }}"
          {%- unless rv.available %} disabled aria-disabled="true"{%- endunless -%}
        >
          <span data-fbtatc-cta-label>{{ cta_label }}</span>
          <span class="sai-fbtatc4z__loader" data-fbtatc-loader hidden aria-hidden="true">
            <svg class="sai-fbtatc4z__spinner" viewBox="0 0 24 24" fill="none" focusable="false">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-opacity="0.25" stroke-width="3"/>
              <path d="M22 12a10 10 0 0 0-10-10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
      </li>
    {%- endfor -%}
  </ul>

  <div class="sai-fbtatc4z__error" data-fbtatc-error role="alert" hidden></div>

  {%- comment -%}
    JSON payload. Per-value `| json` is mandatory inside <script type="application/json">.
    Mirrors the pb3tmxq9 shape so analytics events carry the same envelope
    structure; downstream consumers don't need to know which surface fired.
  {%- endcomment -%}
  <script type="application/json" data-fbtatc-payload>
{
  "main": {{ product.id | json }},
  "currency": {{ shop.currency | json }},
  "moneyFormat": {{ shop.money_format | json }},
  "afterAddAction": {{ after_add_action | json }},
  "ctaLabel": {{ cta_label | json }},
  "variantSelectorMode": {{ variant_selector_mode | json }},
  "products": [
    {%- assign first_product = true -%}
    {%- if show_main_product -%}
      {%- assign first_product = false -%}
      {
        "id": {{ product.id | json }},
        "title": {{ product.title | json }},
        "url": {{ product.url | json }},
        "variantId": {{ product.selected_or_first_available_variant.id | json }},
        "price": {{ product.price | json }},
        "compareAtPrice": {{ product.compare_at_price | json }},
        "available": {{ product.available | json }},
        "options": {{ product.options | json }},
        "imageUrl": {%- if product.featured_image -%}{{ product.featured_image | image_url: width: 320 | json }}{%- else -%}null{%- endif -%},
        "variants": [
          {%- for v in product.variants -%}
            {%- unless forloop.first -%},{%- endunless -%}
            {
              "id": {{ v.id | json }},
              "title": {{ v.title | json }},
              "price": {{ v.price | json }},
              "compareAtPrice": {{ v.compare_at_price | json }},
              "available": {{ v.available | json }},
              "options": {{ v.options | json }},
              "featuredImage": {%- if v.featured_image -%}{{ v.featured_image | image_url: width: 320 | json }}{%- else -%}null{%- endif -%}
            }
          {%- endfor -%}
        ]
      }
    {%- endif -%}
    {%- for handle in fbt_handles -%}
      {%- if handle == product.handle -%}{%- continue -%}{%- endif -%}
      {%- assign r = all_products[handle] -%}
      {%- if r == empty -%}{%- continue -%}{%- endif -%}
      {%- unless first_product -%},{%- endunless -%}
      {%- assign first_product = false -%}
      {
        "id": {{ r.id | json }},
        "title": {{ r.title | json }},
        "url": {{ r.url | json }},
        "variantId": {{ r.selected_or_first_available_variant.id | json }},
        "price": {{ r.price | json }},
        "compareAtPrice": {{ r.compare_at_price | json }},
        "available": {{ r.available | json }},
        "options": {{ r.options | json }},
        "imageUrl": {%- if r.featured_image -%}{{ r.featured_image | image_url: width: 320 | json }}{%- else -%}null{%- endif -%},
        "variants": [
          {%- for v in r.variants -%}
            {%- unless forloop.first -%},{%- endunless -%}
            {
              "id": {{ v.id | json }},
              "title": {{ v.title | json }},
              "price": {{ v.price | json }},
              "compareAtPrice": {{ v.compare_at_price | json }},
              "available": {{ v.available | json }},
              "options": {{ v.options | json }},
              "featuredImage": {%- if v.featured_image -%}{{ v.featured_image | image_url: width: 320 | json }}{%- else -%}null{%- endif -%}
            }
          {%- endfor -%}
        ]
      }
    {%- endfor -%}
  ]
}
  </script>
</sai-fbtatc4z>

{%- endif -%}
