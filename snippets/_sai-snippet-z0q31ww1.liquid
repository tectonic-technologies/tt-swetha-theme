<div style="background:#1f7a3a;color:#fff;padding:12px;margin:8px 0;font:bold 16px sans-serif;">SNIPPET A: before liquid block</div>

{%- liquid
  assign content = variant.content
  assign template_name = template | append: ''
  if content.enabled == nil
    assign enabled = true
  else
    assign enabled = content.enabled
  endif
-%}

<div style="background:#1f7a3a;color:#fff;padding:12px;margin:8px 0;font:bold 16px sans-serif;">SNIPPET B: after liquid block — enabled = {{ enabled }}, template = {{ template_name }}</div>

{%- if enabled -%}
  <div style="background:#c2632e;color:#fff;padding:12px;margin:8px 0;font:bold 16px sans-serif;">SNIPPET C: enabled branch entered</div>

  <button type="button" data-sai-entry style="display:flex;align-items:center;gap:12px;width:calc(100% - 2rem);max-width:1200px;margin:1rem auto;padding:16px;background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:10px;box-shadow:0 2px 6px rgba(0,0,0,0.08);cursor:pointer;font-size:16px;font-weight:700;color:#1a1a1a;">
    <span style="width:28px;height:28px;color:#1f7a3a;">
      <svg viewBox="0 0 32 32" aria-hidden="true"><path fill="currentColor" d="M16 0c1.4 1.9 3.6 1.1 5.6 1.5.4 2 1.9 3.5 4 3.7-.4 2 1 3.8 2.7 5-1 1.8-.5 4 1 5.3-1.5 1.3-2 3.5-1 5.3-1.7 1.2-3.1 3-2.7 5-2.1.2-3.6 1.7-4 3.7-2-.4-4.2.4-5.6 2.3-1.4-1.9-3.6-2.7-5.6-2.3-.4-2-1.9-3.5-4-3.7.4-2-1-3.8-2.7-5 1-1.8.5-4-1-5.3 1.5-1.3 2-3.5 1-5.3 1.7-1.2 3.1-3 2.7-5 2.1-.2 3.6-1.7 4-3.7 2 .4 4.2-.4 5.6-2.3z"/><path d="M21 11 11 21" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>
    </span>
    <span style="flex:1;">View All Offers (DEBUG)</span>
    <span>›</span>
  </button>
{%- endif -%}

<div style="background:#1f7a3a;color:#fff;padding:12px;margin:8px 0;font:bold 16px sans-serif;">SNIPPET D: after enabled block</div>
