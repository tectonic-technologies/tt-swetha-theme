  assign align_h = content.content_align_h | default: 'left'
  assign align_v = content.content_align_v | default: 'middle'
  assign background_type = content.background_type | default: 'image'
  assign title = content.title | default: ''
  assign title_accent = content.title_accent | default: ''
  assign title_animation = content.title_animation | default: 'fade'
  assign subtitle = content.subtitle | default: ''
  assign description = content.description | default: ''
  assign description_highlight = content.description_highlight | default: ''
  assign badge_text = content.badge_text | default: ''
  assign badge_style = content.badge_style | default: 'pill'
  assign badge_position = content.badge_position | default: 'top-left'
  assign rating_value = content.rating_value | default: 0
  assign rating_count = content.rating_count | default: ''
