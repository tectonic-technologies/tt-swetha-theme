{%- doc -%}
  Hero Banner — full-bleed hero with configurable background, overlay, badge,
  headline + accent line, description, CTAs, trust pills, and animated stat cards.

  @param {string} mutation_handle - Mutation handle for DOM scoping (infrastructure)
  @param {string} experience_handle - Experience handle for attribution (infrastructure)
  @param {object} variant - Resolved snippet-instance variant; values live on `variant.content`
  @param {object} mo - spectrum_snippet_instance metaobject drop; carries the `images` reference pool

  Content comes from `variant.content` (Studio) like every other library snippet.
  Per-element visual styling (typography, colors, spacing, borders) is authored in
  the Studio Styling panel via the `style.nodes` declared in meta.json and baked
  into per-instance CSS by the wrapper. Image fields are `{ kind, refId }` markers
  resolved against the `mo.images` pool (a direct `{ url }` is also accepted).

  variant.content fields (see meta.json for the full prop contract):
    layout      : section_width, content_max_width, min_height{mobile,tablet,desktop}, content_align_h,
                  content_align_v, corner_radius, padding_top, padding_bottom, content_reverse, columns_reverse
    background  : background_type, background_image{kind,refId}, background_image_alt, background_video_url,
                  background_poster{...}, background_color, gradient_start, gradient_end, gradient_angle, aspect_ratio
    overlay     : overlay_enabled, overlay_color, overlay_opacity, overlay_gradient_enabled, overlay_gradient_direction
    text        : title, title_accent, title_animation, subtitle, description, description_highlight,
                  inline_asset, inline_asset_image{...}, inline_asset_align
    rating      : show_rating, rating_value, rating_count
    cta         : primary_cta_{text,url,style,radius,size}, show_secondary_cta, secondary_cta_{text,url,style,radius}
    pills       : show_trust_pills, trust_pills[]{icon,text}
    stats       : show_stats, stats_layout, stats[]{icon,number,label,description}, counter_animation,
                  counter_duration, number_format
    countdown   : show_countdown, countdown_target, countdown_style, countdown_end_behavior, countdown_end_message
    animation   : entrance_animation, animation_duration, animation_delay
    mobile      : mobile_layout, hide_on_mobile, hide_on_desktop
    interaction : banner_clickable, click_url, open_new_tab

  Image-typed props arrive as `{ kind:'images', refId }` markers and resolve
  against `mo.images.value` by string-coerced id (Liquid `==` is type-strict).
  inline-list images (stats/pills icons) are snapshots read as `item.icon.originalUrl`.

  @example
  {% render '_sai-snippet-h9k3pdtz', variant: variant, mo: mo, mutation_handle: 'mut-abcd1234', experience_handle: 'summer' %}
{%- enddoc -%}

{%- comment -%}
  Institutional knowledge:
  - Text renders light over an overlaid background regardless of theme palette.
    The default foreground/accent are fixed light values (--sai-h9-fg / --sai-h9-accent)
    so contrast is guaranteed over arbitrary merchant imagery; merchants override
    them through the per-element Styling panel, not theme variables.
  - Liquid-interpolated values are emitted as inline custom properties on the root
    (and the overlay/background layers); all static rules live in the stylesheet
    block and consume those properties via media queries.
  - The whole-banner link is a stretched <a> sibling (z-index below the content),
    never an ancestor of the CTAs — nesting interactive controls inside an anchor
    is invalid HTML.
{%- endcomment -%}

{% stylesheet %}
.sai-h9k3pdtz {
  --sai-h9-fg: #ffffff;
  --sai-h9-accent: #caa75a;
  --sai-h9-muted: rgba(255, 255, 255, 0.78);
  --sai-h9-pill-bg: rgba(255, 255, 255, 0.1);
  --sai-h9-pill-border: rgba(255, 255, 255, 0.22);
  --sai-h9-stat-bg: rgba(12, 12, 12, 0.62);
  --sai-h9-stat-border: rgba(255, 255, 255, 0.22);
  position: relative;
  display: flex;
  width: 100%;
  min-height: var(--sai-h9-min-h-m, 0px);
  padding-top: var(--sai-h9-pad-top, 48px);
  padding-bottom: var(--sai-h9-pad-bottom, 48px);
  border-radius: var(--sai-h9-radius, 0px);
  overflow: hidden;
  color: var(--sai-h9-fg);
  isolation: isolate;
}
.sai-h9k3pdtz--width-boxed {
  max-width: var(--page-width, 1400px);
  margin-inline: auto;
}

.sai-h9k3pdtz__bg,
.sai-h9k3pdtz__overlay,
.sai-h9k3pdtz__banner-link {
  position: absolute;
  inset: 0;
}
.sai-h9k3pdtz__bg { z-index: -2; }
.sai-h9k3pdtz__overlay { z-index: -1; pointer-events: none; }
/* Stretched link covers the whole banner (bg image included). Interactive
   children (CTAs) sit above it; non-interactive content is covered so a click
   anywhere on the banner navigates. Root `isolation: isolate` keeps the
   negative-z background layers contained within the hero. */
.sai-h9k3pdtz__banner-link { z-index: 1; }
.sai-h9k3pdtz__bg-media {
  /* `!important` width/height so the media fills the whole banner even when the
     merchant theme forces `img { height: auto !important }`. For a replaced
     element, `inset:0` does NOT stretch the box (the spec uses the intrinsic
     height and ignores `bottom`), so the absolute positioning alone collapses a
     wide image to its intrinsic strip. A class selector with `!important`
     (0,1,0) outranks the theme's element-level `img !important` (0,0,1) and
     wins the cascade, restoring full cover. */
  position: absolute;
  inset: 0;
  width: 100% !important;
  height: 100% !important;
  object-fit: cover;
  display: block;
}
.sai-h9k3pdtz--parallax .sai-h9k3pdtz__bg {
  top: -8%;
  bottom: -8%;
  will-change: transform;
}

.sai-h9k3pdtz__inner {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: var(--sai-h9-col-gap, clamp(24px, 5vw, 64px));
  width: 100%;
  max-width: var(--page-width, 1400px);
  margin-inline: auto;
  padding-inline: clamp(20px, 5vw, 64px);
}
.sai-h9k3pdtz--width-contained .sai-h9k3pdtz__inner { max-width: 1200px; }
.sai-h9k3pdtz--cols-reverse .sai-h9k3pdtz__inner { flex-direction: row-reverse; }
.sai-h9k3pdtz--valign-top .sai-h9k3pdtz__inner { align-items: flex-start; }
.sai-h9k3pdtz--valign-bottom .sai-h9k3pdtz__inner { align-items: flex-end; }

.sai-h9k3pdtz__content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--sai-h9-content-gap, 20px);
  /* Desktop row: flex-basis 0 (NOT auto) so the column sizes from available
     space, not its own max-content. With `auto`, a long title makes the basis
     as wide as the heading, which + the stats column overflows the row and
     wraps the stats BELOW the content. Basis 0 keeps content + stats side by
     side (content grows into the leftover, capped by max-width). Mobile-stack
     resets this to `flex: 0 0 auto` so the basis never becomes a column height. */
  flex: 1 1 0;
  max-width: var(--sai-h9-content-max, 600px);
}
.sai-h9k3pdtz--align-center .sai-h9k3pdtz__content { text-align: center; align-items: center; margin-inline: auto; }
.sai-h9k3pdtz--align-right .sai-h9k3pdtz__content { text-align: right; align-items: flex-end; }

/* When columns are swapped AND side-by-side (tablet/desktop), mirror the
   content alignment so it hugs the side it now sits on. On the mobile stack
   the columns are not side-by-side, so the base alignment is kept. */
@media screen and (min-width: 750px) {
  .sai-h9k3pdtz--cols-reverse.sai-h9k3pdtz--align-left .sai-h9k3pdtz__content { text-align: right; align-items: flex-end; }
  .sai-h9k3pdtz--cols-reverse.sai-h9k3pdtz--align-right .sai-h9k3pdtz__content { text-align: left; align-items: flex-start; }
}

.sai-h9k3pdtz__subtitle { order: 1; margin: 0; font-size: 0.95rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--sai-h9-muted); }
.sai-h9k3pdtz__title { order: 2; margin: 0; font-family: var(--font-heading-family, inherit); font-weight: 700; font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.05; letter-spacing: -0.01em; }
.sai-h9k3pdtz__title-accent { display: block; color: var(--sai-h9-accent); }
/* Mobile title override (title_mobile prop). When set, two text spans render
   and the breakpoint decides which shows; when unset, the title text is output
   directly (neither span) so this rule is inert. */
.sai-h9k3pdtz__title-text--mobile { display: none; }
@media screen and (max-width: 749px) {
  .sai-h9k3pdtz__title-text--desktop { display: none; }
  .sai-h9k3pdtz__title-text--mobile { display: inline; }
}
.sai-h9k3pdtz__description { order: 4; margin: 0; max-width: 46ch; font-size: 1.05rem; line-height: 1.6; color: var(--sai-h9-muted); }
.sai-h9k3pdtz__highlight { color: var(--sai-h9-fg); font-style: italic; }
.sai-h9k3pdtz__rating { order: 5; display: flex; align-items: center; gap: 10px; font-size: 0.95rem; color: var(--sai-h9-muted); }
.sai-h9k3pdtz__countdown { order: 6; }
.sai-h9k3pdtz__ctas { order: 7; position: relative; z-index: 2; display: flex; flex-wrap: wrap; gap: 12px; }
.sai-h9k3pdtz__pills { order: 8; display: flex; flex-wrap: wrap; gap: 10px; margin: 0; padding: 0; list-style: none; }
.sai-h9k3pdtz--align-center .sai-h9k3pdtz__ctas,
.sai-h9k3pdtz--align-center .sai-h9k3pdtz__pills,
.sai-h9k3pdtz--align-center .sai-h9k3pdtz__rating { justify-content: center; }
.sai-h9k3pdtz--align-right .sai-h9k3pdtz__ctas,
.sai-h9k3pdtz--align-right .sai-h9k3pdtz__pills,
.sai-h9k3pdtz--align-right .sai-h9k3pdtz__rating { justify-content: flex-end; }

/* Mobile alignment override (content_align_h_mobile). Scoped under the mobile
   breakpoint and placed AFTER the base align rules so the same-specificity
   mobile rule wins below 750px; above it, the base (desktop) alignment holds.
   This is how "center on mobile, left on desktop" is expressed. */
@media screen and (max-width: 749px) {
  .sai-h9k3pdtz--align-m-left .sai-h9k3pdtz__content { text-align: left; align-items: flex-start; margin-inline: 0; }
  .sai-h9k3pdtz--align-m-center .sai-h9k3pdtz__content { text-align: center; align-items: center; margin-inline: auto; }
  .sai-h9k3pdtz--align-m-right .sai-h9k3pdtz__content { text-align: right; align-items: flex-end; margin-inline: 0; }
  .sai-h9k3pdtz--align-m-left .sai-h9k3pdtz__ctas,
  .sai-h9k3pdtz--align-m-left .sai-h9k3pdtz__pills,
  .sai-h9k3pdtz--align-m-left .sai-h9k3pdtz__rating { justify-content: flex-start; }
  .sai-h9k3pdtz--align-m-center .sai-h9k3pdtz__ctas,
  .sai-h9k3pdtz--align-m-center .sai-h9k3pdtz__pills,
  .sai-h9k3pdtz--align-m-center .sai-h9k3pdtz__rating { justify-content: center; }
  .sai-h9k3pdtz--align-m-right .sai-h9k3pdtz__ctas,
  .sai-h9k3pdtz--align-m-right .sai-h9k3pdtz__pills,
  .sai-h9k3pdtz--align-m-right .sai-h9k3pdtz__rating { justify-content: flex-end; }
}

/* content_reverse swaps the description and the trust-pills row */
.sai-h9k3pdtz--reverse .sai-h9k3pdtz__description { order: 8; }
.sai-h9k3pdtz--reverse .sai-h9k3pdtz__pills { order: 4; }

.sai-h9k3pdtz__inline-asset { max-height: 1em; width: auto; vertical-align: middle; }
.sai-h9k3pdtz__inline-asset--right { float: right; }

/* Badge — in-flow, first item in the content column */
.sai-h9k3pdtz__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  width: fit-content;
  max-width: 100%;
  padding: 8px 14px;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--sai-h9-fg);
  /* Chrome-free by default — no background, no border. Merchants add a fill or
     outline via the Styling panel (Badge → Background / Border) if they want
     one; the radius stays so a panel-added fill renders as a pill. */
  background: transparent;
  border: none;
  border-radius: 999px;
}
.sai-h9k3pdtz__badge-icon { width: 14px; height: 14px; flex: none; }
.sai-h9k3pdtz__badge--tag { border-radius: 4px; }
.sai-h9k3pdtz__badge--ribbon { border-radius: 4px; }
.sai-h9k3pdtz__badge--corner { border-radius: 4px; }
/* Accent bar (badge_accent). A detached rounded bar drawn as ::before, kept
   off the text by the flex gap. Mobile (base): the badge stacks as a column so
   the bar (order:1) sits below the text as a short horizontal underline. Web
   (≥750px): the badge is a row and the bar (order:-1) sits to the left as a
   vertical bar ~one line tall. Thickness + colour are props. */
.sai-h9k3pdtz__badge--accent { flex-direction: column; align-items: flex-start; gap: 10px; }
.sai-h9k3pdtz__badge--accent::before {
  content: "";
  flex: none;
  order: 1;
  width: 28px;
  height: var(--sai-h9-badge-accent-thickness, 4px);
  border-radius: 999px;
  background: var(--sai-h9-badge-accent-color, #ff3b20);
}
@media screen and (min-width: 750px) {
  .sai-h9k3pdtz__badge--accent { flex-direction: row; align-items: center; }
  .sai-h9k3pdtz__badge--accent::before { order: -1; width: var(--sai-h9-badge-accent-thickness, 4px); height: 1.4em; }
}

/* CTAs */
.sai-h9k3pdtz__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 14px 26px;
  font-weight: 600;
  font-size: 0.9rem;
  letter-spacing: 0.04em;
  text-decoration: none;
  cursor: pointer;
  border: 1px solid transparent;
  border-radius: 999px;
  transition: transform 0.14s ease, opacity 0.15s ease;
}
/* Hover lifts the button; click presses it down (scale). Active overrides
   hover so the press reads even while hovering. */
.sai-h9k3pdtz__cta:hover { opacity: 0.96; transform: translateY(-2px); }
.sai-h9k3pdtz__cta:active { transform: scale(0.93); }
@media (prefers-reduced-motion: reduce) {
  .sai-h9k3pdtz__cta { transition: none; }
  .sai-h9k3pdtz__cta:active { transform: none; }
}
.sai-h9k3pdtz__cta:focus-visible { outline: 2px solid var(--sai-h9-fg); outline-offset: 2px; }
.sai-h9k3pdtz__cta--filled { background: var(--sai-h9-fg); color: #111111; }
.sai-h9k3pdtz__cta--outlined { background: transparent; color: var(--sai-h9-fg); border-color: var(--sai-h9-pill-border); }
.sai-h9k3pdtz__cta--ghost { background: var(--sai-h9-pill-bg); color: var(--sai-h9-fg); }
.sai-h9k3pdtz__cta--text { background: transparent; color: var(--sai-h9-fg); padding-inline: 4px; border: 0; text-decoration: underline; }
.sai-h9k3pdtz__cta--square { border-radius: 4px; }
.sai-h9k3pdtz__cta--rounded { border-radius: 10px; }
.sai-h9k3pdtz__cta--pill { border-radius: 999px; }
.sai-h9k3pdtz__cta--small { padding: 10px 18px; font-size: 0.8rem; }
.sai-h9k3pdtz__cta--large { padding: 18px 34px; font-size: 1rem; }

/* Trust pills */
.sai-h9k3pdtz__pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  font-size: 0.85rem;
  color: var(--sai-h9-muted);
  background: var(--sai-h9-pill-bg);
  border: 1px solid var(--sai-h9-pill-border);
  border-radius: 999px;
  /* Portal-configurable cap (Trust pill max width); 0 → none (fit content). */
  max-width: var(--sai-h9-pill-max, none);
}
.sai-h9k3pdtz__pill-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--sai-h9-accent); flex: none; }
.sai-h9k3pdtz__pill-icon { width: 16px; height: 16px; flex: none; color: var(--sai-h9-accent); display: inline-flex; }
.sai-h9k3pdtz__pill-icon svg { width: 16px; height: 16px; stroke: currentColor; fill: none; }
img.sai-h9k3pdtz__pill-icon { object-fit: contain; }

.sai-h9k3pdtz__stars { display: inline-flex; gap: 2px; color: var(--sai-h9-accent); }
.sai-h9k3pdtz__star { width: 16px; height: 16px; }

/* Stats */
.sai-h9k3pdtz__stats {
  display: flex;
  flex-direction: column;
  gap: var(--sai-h9-stats-gap, 16px);
  /* Right-column width (desktop row). Portal-configurable via Stats column
     width; 0 falls back to the 320px default. Mobile-stack resets the basis. */
  flex: 0 1 var(--sai-h9-stats-max, 320px);
}
.sai-h9k3pdtz__stats--horizontal { flex-direction: row; flex-wrap: wrap; gap: var(--sai-h9-stats-gap, 16px); }
/* Grid: column count is per-breakpoint (mobile / tablet / desktop vars). */
.sai-h9k3pdtz__stats--grid { display: grid; grid-template-columns: repeat(var(--sai-h9-grid-m, 1), minmax(0, 1fr)); gap: var(--sai-h9-stats-gap, 16px); }
@media screen and (min-width: 750px) {
  .sai-h9k3pdtz__stats--grid { grid-template-columns: repeat(var(--sai-h9-grid-t, 2), minmax(0, 1fr)); }
}
@media screen and (min-width: 990px) {
  .sai-h9k3pdtz__stats--grid { grid-template-columns: repeat(var(--sai-h9-grid-d, 2), minmax(0, 1fr)); }
}
/* Explicit per-card grid placement (Grid layout, desktop ≥750px). Each card may
   carry `--sai-h9-stat-row` / `--sai-h9-stat-col` (set inline from its row/col
   fields). Applied only ≥750px so a card placed at column 2 doesn't force a
   second column on mobile (where the grid stays single-column or follows its
   mobile-layout override). Cells with no card assigned stay empty — that's how
   you get an offset/"staggered" look (e.g. cards at 1,2 / 2,1 / 2,2, hole at
   1,1). `--sai-h9-grid-rows` reserves a fixed row count (0 = auto). */
@media screen and (min-width: 750px) {
  .sai-h9k3pdtz__stats--grid { grid-template-rows: var(--sai-h9-grid-rows, none); align-items: start; }
  .sai-h9k3pdtz__stats--grid .sai-h9k3pdtz__stat { grid-column: var(--sai-h9-stat-col, auto); grid-row: var(--sai-h9-stat-row, auto); }
}
/* Mobile stats-layout override (stats_layout_mobile prop). Below 750px the
   `--m-*` class forces a layout independent of the desktop choice. Placed after
   every layout rule so the same-specificity mobile rule wins by source order;
   only active under the breakpoint. The staggered spacer is already hidden
   below 750px (base rule), so no per-override hiding is needed. */
@media screen and (max-width: 749px) {
  .sai-h9k3pdtz__stats--m-vertical { display: flex; flex-direction: column; }
  .sai-h9k3pdtz__stats--m-horizontal { display: flex; flex-direction: row; flex-wrap: wrap; }
  .sai-h9k3pdtz__stats--m-grid { display: grid; grid-template-columns: repeat(var(--sai-h9-grid-m, 1), minmax(0, 1fr)); }
}
/* Label-on-top: render the label above the number/icon row. */
.sai-h9k3pdtz__stats--label-top .sai-h9k3pdtz__stat-label { order: -1; }
.sai-h9k3pdtz__stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 16px 20px;
  background: var(--sai-h9-stat-bg);
  border: 1px solid var(--sai-h9-stat-border);
  border-radius: 14px;
  box-shadow: var(--sai-h9-stat-shadow, none);
  -webkit-backdrop-filter: blur(var(--sai-h9-stat-blur, 8px));
  backdrop-filter: blur(var(--sai-h9-stat-blur, 8px));
  /* min-width:0 lets the card shrink inside a grid/flex track (default min
     content-size is auto, which refuses to shrink below a long number). The
     query container for card-relative number sizing lives on __stat-head, NOT
     here: a grid ITEM that is also an inline-size container stretches its row
     to a square-ish block size (Chromium grid+containment interaction),
     ballooning every card. The head is an in-flow child, not a grid item, so
     it can be a container without that side effect. */
  min-width: 0;
}
.sai-h9k3pdtz__stat-head {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  /* Query container so the number sizes to the card width (cqi) instead of the
     viewport (vw) — "37000+" scales down to fit a narrow column rather than
     overflowing it. Head width tracks the card's content-box width. */
  container-type: inline-size;
}
.sai-h9k3pdtz__stat-icon { width: 32px; height: 32px; object-fit: contain; flex: none; }
.sai-h9k3pdtz__stat-number { font-size: clamp(1.4rem, 16cqi, 2.4rem); font-weight: 700; line-height: 1; color: var(--sai-h9-accent); font-variant-numeric: tabular-nums; overflow-wrap: anywhere; }
.sai-h9k3pdtz__stat-label { font-size: 0.95rem; font-weight: 600; color: var(--sai-h9-fg); }
.sai-h9k3pdtz__stat-desc { font-size: 0.8rem; color: var(--sai-h9-muted); }

/* Countdown — number over label, thin vertical dividers between units */
.sai-h9k3pdtz__countdown { display: inline-flex; align-items: stretch; }
.sai-h9k3pdtz__cd-unit { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 0 clamp(14px, 2.5vw, 24px); }
.sai-h9k3pdtz__cd-unit + .sai-h9k3pdtz__cd-unit { border-left: 1px solid var(--sai-h9-pill-border); }
/* Fixed min-width + tabular figures so ticking digits never resize the cell
   (prevents the per-second left/right layout shift). */
.sai-h9k3pdtz__cd-num { display: inline-block; min-width: 2ch; text-align: center; font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums; }
.sai-h9k3pdtz__cd-lbl { font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--sai-h9-muted); }
/* Boxes: each unit gets its own panel instead of dividers */
.sai-h9k3pdtz__countdown--boxes .sai-h9k3pdtz__cd-unit { padding: 10px 14px; min-width: 56px; background: var(--sai-h9-pill-bg); border: 1px solid var(--sai-h9-pill-border); border-radius: 10px; }
.sai-h9k3pdtz__countdown--boxes { gap: 10px; }
.sai-h9k3pdtz__countdown--boxes .sai-h9k3pdtz__cd-unit + .sai-h9k3pdtz__cd-unit { border-left: 1px solid var(--sai-h9-pill-border); }
/* Minimal: tight, inline number + label, no dividers */
.sai-h9k3pdtz__countdown--minimal { gap: 12px; }
.sai-h9k3pdtz__countdown--minimal .sai-h9k3pdtz__cd-unit { flex-direction: row; gap: 4px; padding: 0; }
.sai-h9k3pdtz__countdown--minimal .sai-h9k3pdtz__cd-unit + .sai-h9k3pdtz__cd-unit { border-left: 0; }
.sai-h9k3pdtz__countdown--minimal .sai-h9k3pdtz__cd-num { font-size: 1.1rem; }
.sai-h9k3pdtz__countdown--minimal .sai-h9k3pdtz__cd-lbl { font-size: 0.85rem; text-transform: none; letter-spacing: 0; }

/* Entrance animation — fade is opacity-only (no positional/sweep motion) */
.sai-h9k3pdtz__content,
.sai-h9k3pdtz__stats { transition: opacity var(--sai-h9-anim-duration, 600ms) ease var(--sai-h9-anim-delay, 0ms), transform var(--sai-h9-anim-duration, 600ms) ease var(--sai-h9-anim-delay, 0ms); }
.sai-h9k3pdtz--js.sai-h9k3pdtz--anim-fade:not(.is-in) .sai-h9k3pdtz__content,
.sai-h9k3pdtz--js.sai-h9k3pdtz--anim-fade:not(.is-in) .sai-h9k3pdtz__stats { opacity: 0; }
.sai-h9k3pdtz--js.sai-h9k3pdtz--anim-zoom:not(.is-in) .sai-h9k3pdtz__content,
.sai-h9k3pdtz--js.sai-h9k3pdtz--anim-zoom:not(.is-in) .sai-h9k3pdtz__stats { opacity: 0; transform: scale(0.96); }

@media screen and (min-width: 750px) {
  .sai-h9k3pdtz { min-height: var(--sai-h9-min-h-t, 0px); }
}
@media screen and (min-width: 990px) {
  .sai-h9k3pdtz { min-height: var(--sai-h9-min-h-d, 0px); }
}
@media screen and (max-width: 749px) {
  /* Column stack: group content + stats from the top with the normal gap,
     instead of inheriting the desktop `space-between` (which spreads them to
     opposite ends and leaves a large empty gap when content is short). */
  .sai-h9k3pdtz--mobile-stack .sai-h9k3pdtz__inner { flex-direction: column; align-items: stretch; justify-content: flex-start; }
  /* In the column stack, reset the row-axis flex bases — both columns carry a
     flex-basis sized for the side-by-side (row) layout (content 460px, stats
     320px). Once the inner flips to `column`, that basis becomes a *height* and
     stretches each block far taller than its content. Collapse to content. */
  .sai-h9k3pdtz--mobile-stack .sai-h9k3pdtz__content,
  .sai-h9k3pdtz--mobile-stack .sai-h9k3pdtz__stats { flex: 0 0 auto; }
  .sai-h9k3pdtz--mobile-hide-stats .sai-h9k3pdtz__stats { display: none; }
  .sai-h9k3pdtz--hide-mobile { display: none; }
}
@media screen and (min-width: 750px) {
  .sai-h9k3pdtz--hide-desktop { display: none; }
}
@media (prefers-reduced-motion: reduce) {
  .sai-h9k3pdtz__content,
  .sai-h9k3pdtz__stats { transition: none; opacity: 1; transform: none; }
  .sai-h9k3pdtz__cta { transition: none; }
}
{% endstylesheet %}

{%- liquid
  assign content = variant.content

  assign section_width = content.section_width | default: 'full'
  assign align_h = content.content_align_h | default: 'left'
  assign align_v = content.content_align_v | default: 'middle'
  assign align_h_mobile = content.content_align_h_mobile | default: 'inherit'
  comment
    Gaps. content_gap = vertical rhythm of the text stack; stats_gap = between
    stat cards; column_gap = between the content and stats columns (0 keeps the
    responsive clamp default so a short banner still breathes).
  endcomment
  assign content_gap = content.content_gap | default: 20
  assign stats_gap = content.stats_gap | default: 16
  assign column_gap = content.column_gap | default: 0
  if column_gap > 0
    assign col_gap_css = column_gap | append: 'px'
  else
    assign col_gap_css = 'clamp(24px, 5vw, 64px)'
  endif
  assign background_type = content.background_type | default: 'image'
  assign title = content.title | default: ''
  assign title_mobile = content.title_mobile | default: ''
  assign title_accent = content.title_accent | default: ''
  assign title_animation = content.title_animation | default: 'fade'
  assign subtitle = content.subtitle | default: ''
  assign description = content.description | default: ''
  assign description_highlight = content.description_highlight | default: ''
  assign badge_text = content.badge_text | default: ''
  assign badge_style = content.badge_style | default: 'pill'
  comment
    Badge accent bar: a detached rounded bar drawn as the badge ::before. Opt-in
    (default off). Left of the text on web (≥750px), below it on mobile.
  endcomment
  assign badge_accent = content.badge_accent
  if badge_accent == nil
    assign badge_accent = false
  endif
  assign badge_accent_color = content.badge_accent_color | default: '#FF3B20'
  assign badge_accent_thickness = content.badge_accent_thickness | default: 4
  assign rating_value = content.rating_value | default: 0
  assign rating_count = content.rating_count | default: ''
  assign primary_text = content.primary_cta_text | default: ''
  assign primary_url = content.primary_cta_url | default: ''
  assign primary_style = content.primary_cta_style | default: 'filled'
  assign primary_radius = content.primary_cta_radius | default: 'pill'
  assign primary_size = content.primary_cta_size | default: 'medium'
  assign secondary_text = content.secondary_cta_text | default: ''
  assign secondary_url = content.secondary_cta_url | default: ''
  assign secondary_style = content.secondary_cta_style | default: 'outlined'
  assign secondary_radius = content.secondary_cta_radius | default: 'pill'
  assign stats_layout = content.stats_layout | default: 'vertical'
  assign stats_layout_mobile = content.stats_layout_mobile | default: 'inherit'
  assign stats_label_position = content.stats_label_position | default: 'bottom'
  assign number_format = content.number_format | default: 'auto'
  assign counter_duration = content.counter_duration | default: 2000
  assign entrance = content.entrance_animation | default: 'fade'
  assign anim_duration = content.animation_duration | default: 600
  assign anim_delay = content.animation_delay | default: 0
  assign mobile_layout = content.mobile_layout | default: 'stack'
  assign inline_align = content.inline_asset_align | default: 'left'

  assign content_max = content.content_max_width | default: 600
  assign corner_radius = content.corner_radius | default: 0
  assign pad_top = content.padding_top | default: 48
  assign pad_bottom = content.padding_bottom | default: 48

  comment
    Right-column (stats) width and trust-pill cap are portal-configurable. 0 is
    the "no explicit size" sentinel: stats falls back to the 320px default
    flex-basis, pills fall back to content width (max-width:none). Emitting a
    CSS keyword/length here lets the static rules consume one var with a sane
    fallback instead of branching in CSS.
  endcomment
  assign stats_max = content.stats_max_width | default: 0
  if stats_max > 0
    assign stats_basis = stats_max | append: 'px'
  else
    assign stats_basis = '320px'
  endif
  assign pill_max = content.pill_max_width | default: 0
  if pill_max > 0
    assign pill_cap = pill_max | append: 'px'
  else
    assign pill_cap = 'none'
  endif

  comment
    Stat-card backdrop blur + box-shadow. These two effects are outside the
    Styling-panel schema (effects = a fixed black box-shadow preset; no
    filter/blur category, no shadow colour), so they live as props. Shadow is
    only emitted when a colour is set; size drives blur radius with half that
    as the vertical offset.
  endcomment
  assign stat_blur = content.stat_blur | default: 8
  assign stat_shadow_size = content.stat_shadow_size | default: 24
  assign stat_shadow_color = content.stat_shadow_color
  if stat_shadow_color == blank
    assign stat_shadow = 'none'
  else
    assign stat_shadow_y = stat_shadow_size | divided_by: 2
    assign stat_shadow = '0 ' | append: stat_shadow_y | append: 'px ' | append: stat_shadow_size | append: 'px ' | append: stat_shadow_color
  endif

  comment
    Minimum height defaults to 0 (fit-content) so the banner — and its
    background image, which fills the box — takes only the space its content
    needs. Merchants raise it per breakpoint for a taller hero.
  endcomment
  assign mh = content.min_height
  assign mh_m = 0
  assign mh_t = 0
  assign mh_d = 0
  if mh.mobile
    assign mh_m = mh.mobile
  endif
  if mh.tablet
    assign mh_t = mh.tablet
  endif
  if mh.desktop
    assign mh_d = mh.desktop
  endif

  assign grid_cols = content.stats_grid_columns
  assign grid_m = 1
  assign grid_t = 2
  assign grid_d = 2
  if grid_cols.mobile
    assign grid_m = grid_cols.mobile
  endif
  if grid_cols.tablet
    assign grid_t = grid_cols.tablet
  endif
  if grid_cols.desktop
    assign grid_d = grid_cols.desktop
  endif
  comment
    Grid rows: 0 = auto (rows grow as cards are placed). >0 reserves a fixed
    row count via grid-template-rows; `none` keeps the implicit-row default.
  endcomment
  assign grid_rows = content.stats_grid_rows | default: 0
  if grid_rows > 0
    assign grid_rows_css = 'repeat(' | append: grid_rows | append: ', auto)'
  else
    assign grid_rows_css = 'none'
  endif

  if content.overlay_enabled == nil
    assign overlay_enabled = true
  else
    assign overlay_enabled = content.overlay_enabled
  endif
  assign overlay_color = content.overlay_color | default: '#000000'
  assign overlay_opacity = content.overlay_opacity | default: 45
  if content.overlay_gradient_enabled == nil
    assign overlay_gradient_enabled = true
  else
    assign overlay_gradient_enabled = content.overlay_gradient_enabled
  endif
  assign overlay_direction = content.overlay_gradient_direction | default: 'left-right'

  if content.show_background == nil
    assign show_background = true
  else
    assign show_background = content.show_background
  endif
  if content.show_title == nil
    assign show_title = true
  else
    assign show_title = content.show_title
  endif
  if content.show_subtitle == nil
    assign show_subtitle = true
  else
    assign show_subtitle = content.show_subtitle
  endif
  if content.show_description == nil
    assign show_description = true
  else
    assign show_description = content.show_description
  endif
  if content.show_primary_cta == nil
    assign show_primary_cta = true
  else
    assign show_primary_cta = content.show_primary_cta
  endif
  if content.show_badge == nil
    assign show_badge = true
  else
    assign show_badge = content.show_badge
  endif
  if content.show_rating == nil
    assign show_rating = true
  else
    assign show_rating = content.show_rating
  endif
  if content.show_secondary_cta == nil
    assign show_secondary_cta = true
  else
    assign show_secondary_cta = content.show_secondary_cta
  endif
  if content.show_trust_pills == nil
    assign show_trust_pills = true
  else
    assign show_trust_pills = content.show_trust_pills
  endif
  if content.show_stats == nil
    assign show_stats = true
  else
    assign show_stats = content.show_stats
  endif
  if content.counter_animation == nil
    assign counter_animation = true
  else
    assign counter_animation = content.counter_animation
  endif
  assign content_reverse = content.content_reverse
  assign columns_reverse = content.columns_reverse
  assign show_countdown = content.show_countdown
  assign inline_asset = content.inline_asset
  assign banner_clickable = content.banner_clickable
-%}

{%- comment -%}
  Resolve images for both content sources:
  - shop metafield: each image is a plain object carrying a direct `.url`.
  - variant.content (Studio): each image is a `{ kind, refId }` marker resolved
    against the `mo.images` pool by string-coerced id (Liquid `==` is type-strict).
  Final per-image URL lands in *_src (badge/poster/inline) or bg_image_url; the
  pool drop also lands in bg_image so the metaobject path keeps srcset + dims.
{%- endcomment -%}
{%- assign bg_image = nil -%}
{%- assign bg_image_url = content.background_image.url -%}
{%- assign mobile_bg_src = content.background_image_mobile.url -%}
{%- assign badge_src = content.badge_icon.url -%}
{%- assign poster_src = content.background_poster.url -%}
{%- assign inline_src = content.inline_asset_image.url -%}
{%- if mo.images.value -%}
  {%- for _img in mo.images.value -%}
    {%- assign _iid = _img.id | append: '' -%}
    {%- if content.background_image.refId == _iid -%}{%- assign bg_image = _img -%}{%- endif -%}
    {%- if content.background_image_mobile.refId == _iid -%}{%- assign mobile_bg_src = _img | image_url: width: 1400 -%}{%- endif -%}
    {%- if content.badge_icon.refId == _iid -%}{%- assign badge_src = _img | image_url: width: 48 -%}{%- endif -%}
    {%- if content.background_poster.refId == _iid -%}{%- assign poster_src = _img | image_url: width: 1600 -%}{%- endif -%}
    {%- if content.inline_asset_image.refId == _iid -%}{%- assign inline_src = _img | image_url: width: 200 -%}{%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%}── Overlay background value (Liquid-interpolated, fail-safe) ──{%- endcomment -%}
{%- assign _ov = 'color-mix(in srgb, ' | append: overlay_color | append: ' ' | append: overlay_opacity | append: '%, transparent)' -%}
{%- if overlay_gradient_enabled -%}
  {%- case overlay_direction -%}
    {%- when 'top-bottom' -%}{%- assign overlay_bg = 'linear-gradient(180deg, ' | append: _ov | append: ', transparent)' -%}
    {%- when 'bottom-top' -%}{%- assign overlay_bg = 'linear-gradient(0deg, ' | append: _ov | append: ', transparent)' -%}
    {%- when 'radial' -%}{%- assign overlay_bg = 'radial-gradient(circle at 30% 50%, transparent, ' | append: _ov | append: ')' -%}
    {%- else -%}{%- assign overlay_bg = 'linear-gradient(90deg, ' | append: _ov | append: ', transparent)' -%}
  {%- endcase -%}
{%- else -%}
  {%- assign overlay_bg = _ov -%}
{%- endif -%}

{%- comment -%}── Build root modifier classes ──{%- endcomment -%}
{%- assign root_class = 'sai-h9k3pdtz' -%}
{%- assign root_class = root_class | append: ' sai-h9k3pdtz--width-' | append: section_width -%}
{%- assign root_class = root_class | append: ' sai-h9k3pdtz--align-' | append: align_h -%}
{%- if align_h_mobile != 'inherit' -%}{%- assign root_class = root_class | append: ' sai-h9k3pdtz--align-m-' | append: align_h_mobile -%}{%- endif -%}
{%- assign root_class = root_class | append: ' sai-h9k3pdtz--valign-' | append: align_v -%}
{%- if entrance == 'fade' or entrance == 'zoom' -%}{%- assign root_class = root_class | append: ' sai-h9k3pdtz--anim-' | append: entrance -%}{%- endif -%}
{%- if entrance == 'parallax' -%}{%- assign root_class = root_class | append: ' sai-h9k3pdtz--parallax' -%}{%- endif -%}
{%- if content_reverse -%}{%- assign root_class = root_class | append: ' sai-h9k3pdtz--reverse' -%}{%- endif -%}
{%- if columns_reverse -%}{%- assign root_class = root_class | append: ' sai-h9k3pdtz--cols-reverse' -%}{%- endif -%}
{%- if mobile_layout == 'stack' -%}{%- assign root_class = root_class | append: ' sai-h9k3pdtz--mobile-stack' -%}{%- endif -%}
{%- if mobile_layout == 'hide_stats' -%}{%- assign root_class = root_class | append: ' sai-h9k3pdtz--mobile-hide-stats' -%}{%- endif -%}
{%- if content.hide_on_mobile -%}{%- assign root_class = root_class | append: ' sai-h9k3pdtz--hide-mobile' -%}{%- endif -%}
{%- if content.hide_on_desktop -%}{%- assign root_class = root_class | append: ' sai-h9k3pdtz--hide-desktop' -%}{%- endif -%}

{%- capture root_style -%}--sai-h9-min-h-m: {{ mh_m }}px; --sai-h9-min-h-t: {{ mh_t }}px; --sai-h9-min-h-d: {{ mh_d }}px; --sai-h9-radius: {{ corner_radius }}px; --sai-h9-pad-top: {{ pad_top }}px; --sai-h9-pad-bottom: {{ pad_bottom }}px; --sai-h9-content-max: {{ content_max }}px; --sai-h9-stats-max: {{ stats_basis }}; --sai-h9-pill-max: {{ pill_cap }}; --sai-h9-stat-blur: {{ stat_blur }}px; --sai-h9-stat-shadow: {{ stat_shadow }}; --sai-h9-content-gap: {{ content_gap }}px; --sai-h9-stats-gap: {{ stats_gap }}px; --sai-h9-col-gap: {{ col_gap_css }}; --sai-h9-badge-accent-color: {{ badge_accent_color }}; --sai-h9-badge-accent-thickness: {{ badge_accent_thickness }}px; --sai-h9-anim-duration: {{ anim_duration }}ms; --sai-h9-anim-delay: {{ anim_delay }}ms; --sai-h9-grid-m: {{ grid_m }}; --sai-h9-grid-t: {{ grid_t }}; --sai-h9-grid-d: {{ grid_d }}; --sai-h9-grid-rows: {{ grid_rows_css }};{%- endcapture -%}

<div class="{{ root_class }}"
     style="{{ root_style }}"
     data-counter-animate="{% if counter_animation %}true{% else %}false{% endif %}"
     data-counter-duration="{{ counter_duration }}"
     data-entrance="{{ entrance }}"
     data-title-animation="{{ title_animation }}">

  {%- comment -%}── Background ──{%- endcomment -%}
  {%- if show_background -%}
  <div class="sai-h9k3pdtz__bg" aria-hidden="true"
    {%- if background_type == 'color' %} style="background-color: {{ content.background_color | default: '#0d0d0d' }}"{% endif -%}
    {%- if background_type == 'gradient' %} style="background: linear-gradient({{ content.gradient_angle | default: 135 }}deg, {{ content.gradient_start | default: '#1f1f1f' }}, {{ content.gradient_end | default: '#000000' }})"{% endif -%}
  >
    {%- if background_type == 'image' and bg_image != blank -%}
      <picture>
        {%- if mobile_bg_src != blank %}<source media="(max-width: 749px)" srcset="{{ mobile_bg_src }}">{% endif -%}
        <img class="sai-h9k3pdtz__bg-media"
             src="{{ bg_image | image_url: width: 2400 }}"
             srcset="{{ bg_image | image_url: width: 800 }} 800w, {{ bg_image | image_url: width: 1600 }} 1600w, {{ bg_image | image_url: width: 2400 }} 2400w"
             sizes="100vw"
             {%- if bg_image.width and bg_image.height %} width="{{ bg_image.width }}" height="{{ bg_image.height }}"{% endif %}
             alt="{{ content.background_image_alt | default: '' | escape }}"
             loading="eager" fetchpriority="high">
      </picture>
    {%- elsif background_type == 'image' and bg_image_url != blank -%}
      <picture>
        {%- if mobile_bg_src != blank %}<source media="(max-width: 749px)" srcset="{{ mobile_bg_src }}">{% endif -%}
        <img class="sai-h9k3pdtz__bg-media"
             src="{{ bg_image_url }}"
             sizes="100vw"
             {%- if content.background_image.width and content.background_image.height %} width="{{ content.background_image.width }}" height="{{ content.background_image.height }}"{% endif %}
             alt="{{ content.background_image_alt | default: '' | escape }}"
             loading="eager" fetchpriority="high">
      </picture>
    {%- elsif background_type == 'image' and mobile_bg_src != blank -%}
      <picture>
        <source media="(max-width: 749px)" srcset="{{ mobile_bg_src }}">
        <img class="sai-h9k3pdtz__bg-media" src="{{ mobile_bg_src }}" sizes="100vw"
             alt="{{ content.background_image_alt | default: '' | escape }}" loading="eager" fetchpriority="high">
      </picture>
    {%- elsif background_type == 'video' and content.background_video_url != blank -%}
      <video class="sai-h9k3pdtz__bg-media" autoplay muted loop playsinline
        {%- if poster_src != blank %} poster="{{ poster_src }}"{% endif %}>
        <source src="{{ content.background_video_url }}">
      </video>
    {%- endif -%}
  </div>
  {%- endif -%}

  {%- if overlay_enabled -%}
    <div class="sai-h9k3pdtz__overlay" aria-hidden="true" style="background: {{ overlay_bg }}"></div>
  {%- endif -%}

  {%- if banner_clickable and content.click_url != blank -%}
    <a class="sai-h9k3pdtz__banner-link" href="{{ content.click_url }}"
      {%- if content.open_new_tab %} target="_blank" rel="noopener noreferrer"{% endif %}
      aria-label="{{ title | strip_newlines | escape }}"></a>
  {%- endif -%}

  <div class="sai-h9k3pdtz__inner">
    <div class="sai-h9k3pdtz__content">
      {%- comment -%}── Badge (in-flow, first item so it spaces from the title) ──{%- endcomment -%}
      {%- if show_badge and badge_text != blank -%}
        <div class="sai-h9k3pdtz__badge sai-h9k3pdtz__badge--{{ badge_style }}{% if badge_accent %} sai-h9k3pdtz__badge--accent{% endif %}">
          {%- if badge_src != blank -%}
            <img class="sai-h9k3pdtz__badge-icon" src="{{ badge_src }}" alt="" loading="lazy" width="14" height="14">
          {%- endif -%}
          <span>{{ badge_text | escape }}</span>
        </div>
      {%- endif -%}

      {%- if show_subtitle and subtitle != blank -%}
        <p class="sai-h9k3pdtz__subtitle">{{ subtitle | escape }}</p>
      {%- endif -%}

      {%- if show_title and title != blank or title_mobile != blank or title_accent != blank -%}
        <h2 class="sai-h9k3pdtz__title">
          {%- if inline_asset and inline_src != blank -%}
            <img class="sai-h9k3pdtz__inline-asset sai-h9k3pdtz__inline-asset--{{ inline_align }}" src="{{ inline_src }}" alt="" loading="lazy">
          {%- endif -%}
          {%- if title_mobile != blank -%}
            <span class="sai-h9k3pdtz__title-text sai-h9k3pdtz__title-text--desktop">{{ title | escape | newline_to_br }}</span>
            <span class="sai-h9k3pdtz__title-text sai-h9k3pdtz__title-text--mobile">{{ title_mobile | escape | newline_to_br }}</span>
          {%- else -%}
            {{ title | escape | newline_to_br }}
          {%- endif -%}
          {%- if title_accent != blank -%}
            <span class="sai-h9k3pdtz__title-accent">{{ title_accent | escape }}</span>
          {%- endif -%}
        </h2>
      {%- endif -%}

      {%- if show_description and description != blank -%}
        {%- assign desc_out = description | escape -%}
        {%- assign _hl_e = description_highlight | escape -%}
        {%- if description_highlight != blank and desc_out contains _hl_e -%}
          {%- capture _hl -%}<span class="sai-h9k3pdtz__highlight">{{ _hl_e }}</span>{%- endcapture -%}
          {%- assign desc_out = desc_out | replace: _hl_e, _hl -%}
        {%- endif -%}
        <p class="sai-h9k3pdtz__description">{{ desc_out }}</p>
      {%- endif -%}

      {%- if show_rating and rating_count != blank -%}
        <div class="sai-h9k3pdtz__rating">
          {%- assign _full = rating_value | round -%}
          <span class="sai-h9k3pdtz__stars" role="img" aria-label="{{ rating_value }} out of 5 stars">
            {%- for _i in (1..5) -%}
              {%- if _i <= _full -%}
                <svg class="sai-h9k3pdtz__star" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 1.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 15l-5.3 2.6 1-5.8L1.5 7.7l5.9-.9z"/></svg>
              {%- else -%}
                <svg class="sai-h9k3pdtz__star" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M10 1.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 15l-5.3 2.6 1-5.8L1.5 7.7l5.9-.9z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </span>
          <span>{{ rating_count | escape }}</span>
        </div>
      {%- endif -%}

      {%- assign _show_primary = false -%}
      {%- if show_primary_cta and primary_text != blank -%}{%- assign _show_primary = true -%}{%- endif -%}
      {%- assign _show_secondary = false -%}
      {%- if show_secondary_cta and secondary_text != blank -%}{%- assign _show_secondary = true -%}{%- endif -%}
      {%- if _show_primary or _show_secondary -%}
        <div class="sai-h9k3pdtz__ctas">
          {%- if _show_primary -%}
            <a class="sai-h9k3pdtz__cta sai-h9k3pdtz__cta--primary sai-h9k3pdtz__cta--{{ primary_style }} sai-h9k3pdtz__cta--{{ primary_radius }} sai-h9k3pdtz__cta--{{ primary_size }}"
               href="{{ primary_url | default: '#' }}" data-sai-cta="primary">{{ primary_text | escape }}</a>
          {%- endif -%}
          {%- if _show_secondary -%}
            <a class="sai-h9k3pdtz__cta sai-h9k3pdtz__cta--secondary sai-h9k3pdtz__cta--{{ secondary_style }} sai-h9k3pdtz__cta--{{ secondary_radius }}"
               href="{{ secondary_url | default: '#' }}" data-sai-cta="secondary">{{ secondary_text | escape }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if show_countdown and content.countdown_target != blank -%}
        <div class="sai-h9k3pdtz__countdown sai-h9k3pdtz__countdown--{{ content.countdown_style | default: 'divider' }}"
             data-sai-countdown
             data-target="{{ content.countdown_target | escape }}"
             data-end-behavior="{{ content.countdown_end_behavior | default: 'hide' }}"
             data-end-message="{{ content.countdown_end_message | default: '' | escape }}">
          <span class="sai-h9k3pdtz__cd-unit"><span class="sai-h9k3pdtz__cd-num" data-cd="days">00</span><span class="sai-h9k3pdtz__cd-lbl">Days</span></span>
          <span class="sai-h9k3pdtz__cd-unit"><span class="sai-h9k3pdtz__cd-num" data-cd="hours">00</span><span class="sai-h9k3pdtz__cd-lbl">Hrs</span></span>
          <span class="sai-h9k3pdtz__cd-unit"><span class="sai-h9k3pdtz__cd-num" data-cd="minutes">00</span><span class="sai-h9k3pdtz__cd-lbl">Min</span></span>
          <span class="sai-h9k3pdtz__cd-unit"><span class="sai-h9k3pdtz__cd-num" data-cd="seconds">00</span><span class="sai-h9k3pdtz__cd-lbl">Sec</span></span>
        </div>
      {%- endif -%}

      {%- if show_trust_pills and content.trust_pills != blank -%}
        <ul class="sai-h9k3pdtz__pills">
          {%- for _pill in content.trust_pills -%}
            {% render '_sai-snippet-h9k3pdtz-pill', pill: _pill %}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    {%- if show_stats and content.stats != blank -%}
      <div class="sai-h9k3pdtz__stats sai-h9k3pdtz__stats--{{ stats_layout }}{% if stats_layout_mobile != 'inherit' %} sai-h9k3pdtz__stats--m-{{ stats_layout_mobile }}{% endif %} sai-h9k3pdtz__stats--label-{{ stats_label_position }}" role="list">
        {%- for _stat in content.stats -%}
          {% render '_sai-snippet-h9k3pdtz-stat', stat: _stat, number_format: number_format %}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>
<script src="{{ 'sai-snippet-h9k3pdtz.js' | asset_url }}" defer></script>
