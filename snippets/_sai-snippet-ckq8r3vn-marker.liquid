{% doc %}
  Cart CTA Strip — single trust marker (icon + text).

  Rendered in an isolated `{% render %}` scope, so it reads only its explicit
  argument. A custom uploaded image wins; otherwise a bundled named glyph;
  otherwise the icon slot is omitted.

  @param {object} marker - One inline-list item: { text, icon_name?, icon? }
{% enddoc %}

{%- liquid
  assign marker_text = marker.text
  assign icon_name = marker.icon_name
  assign icon_url = ''
  if marker.icon != blank
    if marker.icon.originalUrl != blank
      assign icon_url = marker.icon.originalUrl
    elsif marker.icon.previewUrl != blank
      assign icon_url = marker.icon.previewUrl
    endif
  endif
-%}

{%- if marker_text != blank -%}
  <span class="sai-ckq8r3vn__marker">
    {%- if icon_url != blank -%}
      <span class="sai-ckq8r3vn__marker-icon"><img src="{{ icon_url }}" alt="" loading="lazy" /></span>
    {%- elsif icon_name != blank -%}
      <span class="sai-ckq8r3vn__marker-icon">
        {%- case icon_name -%}
          {%- when 'truck' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M14 17V5a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v11a1 1 0 0 0 1 1h1"/><path d="M14 8h4l3 3v5a1 1 0 0 1-1 1h-1"/><path d="M9 17h6"/><circle cx="6.5" cy="17.5" r="1.8"/><circle cx="17.5" cy="17.5" r="1.8"/></svg>
          {%- when 'refresh' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/></svg>
          {%- when 'shield' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
          {%- when 'lock' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
          {%- when 'leaf' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M11 20A7 7 0 0 1 4 13c0-6 7-9 16-9 0 9-3 16-9 16Z"/><path d="M4 20c2-4 5-7 9-9"/></svg>
          {%- when 'tag' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 7v5l9 9 7-7-9-9H4a1 1 0 0 0-1 1Z"/><circle cx="7.5" cy="7.5" r="1.2"/></svg>
          {%- when 'gift' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="3" y="8" width="18" height="4"/><path d="M5 12v9h14v-9"/><path d="M12 8v13"/><path d="M12 8S10 3 7.5 4.5 9 8 12 8Z"/><path d="M12 8s2-5 4.5-3.5S15 8 12 8Z"/></svg>
          {%- when 'check' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9"/><path d="m8 12 2.5 2.5L16 9"/></svg>
        {%- endcase -%}
      </span>
    {%- endif -%}
    <span class="sai-ckq8r3vn__marker-text">{{ marker_text }}</span>
  </span>
{%- endif -%}
