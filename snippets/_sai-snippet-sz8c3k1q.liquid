{%- comment -%}
  Shoppable Size Chart — modal with measurements, unit toggle,
  size selection, and add-to-cart. Reads the current product from
  the Liquid global and size chart data from the spectrum.size_chart
  product metafield.
{%- endcomment -%}

{% stylesheet %}
.sai-sz8c3k1q {
  display: block;
  font-family: var(--sai-font-body, var(--font-body-family, sans-serif));
}

.sai-sz8c3k1q__trigger {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  font-family: inherit;
  font-size: 13px;
  font-weight: 400;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  text-decoration: underline;
  text-underline-offset: 3px;
  color: var(--sai-color-fg, #000);
  cursor: pointer;
}
.sai-sz8c3k1q__trigger:hover {
  opacity: 0.7;
}
.sai-sz8c3k1q__trigger--button {
  text-decoration: none;
  background: #000;
  color: #fff;
  padding: 8px 16px;
  border-radius: 0;
  font-weight: 600;
}
.sai-sz8c3k1q__trigger--icon {
  text-decoration: none;
  padding: 6px;
}

/* ---------- overlay ---------- */
.sai-sz8c3k1q__overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0);
  padding: 16px;
  visibility: hidden;
  transition: background 0.25s ease, visibility 0.25s;
}
.sai-sz8c3k1q__overlay[data-open="true"] {
  visibility: visible;
  background: rgba(0, 0, 0, 0.5);
}

/* ---------- modal ---------- */
.sai-sz8c3k1q__modal {
  position: relative;
  width: 100%;
  max-width: 440px;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #fff;
  border-radius: 0;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  opacity: 0;
  transform: scale(0.95);
  transition: opacity 0.25s ease, transform 0.25s ease;
}
.sai-sz8c3k1q__overlay[data-open="true"] .sai-sz8c3k1q__modal {
  opacity: 1;
  transform: scale(1);
}

/* ---------- drawer overlay ---------- */
.sai-sz8c3k1q__overlay[data-mode="drawer"] {
  padding: 0;
  align-items: stretch;
  justify-content: flex-end;
}
.sai-sz8c3k1q__overlay[data-mode="drawer"][data-direction="left"] {
  justify-content: flex-start;
}

/* ---------- drawer modal ---------- */
.sai-sz8c3k1q__overlay[data-mode="drawer"] .sai-sz8c3k1q__modal {
  max-height: 100vh;
  height: 100%;
  border-radius: 0;
  box-shadow: -4px 0 24px rgba(0, 0, 0, 0.12);
  opacity: 1;
  transform: translateX(100%);
  transition: transform 0.3s ease;
}
.sai-sz8c3k1q__overlay[data-mode="drawer"][data-open="true"] .sai-sz8c3k1q__modal {
  transform: translateX(0);
}
.sai-sz8c3k1q__overlay[data-mode="drawer"][data-direction="left"] .sai-sz8c3k1q__modal {
  box-shadow: 4px 0 24px rgba(0, 0, 0, 0.12);
  transform: translateX(-100%);
}
.sai-sz8c3k1q__overlay[data-mode="drawer"][data-direction="left"][data-open="true"] .sai-sz8c3k1q__modal {
  transform: translateX(0);
}
.sai-sz8c3k1q__modal-header {
  flex-shrink: 0;
  padding: 24px 24px 0;
}
.sai-sz8c3k1q__modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 0 24px;
}
.sai-sz8c3k1q__modal-footer {
  flex-shrink: 0;
  padding: 0 24px 24px;
}

/* ---------- header ---------- */
.sai-sz8c3k1q__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
}
.sai-sz8c3k1q__title {
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #000;
  margin: 0;
}
.sai-sz8c3k1q__close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  color: #000;
}
.sai-sz8c3k1q__close svg {
  width: 18px;
  height: 18px;
}

/* ---------- product info ---------- */
.sai-sz8c3k1q__product {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
}
.sai-sz8c3k1q__product-image {
  width: 72px;
  height: 90px;
  object-fit: cover;
  border-radius: 0;
  flex-shrink: 0;
  background: #f5f5f5;
}
.sai-sz8c3k1q__product-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4px;
}
.sai-sz8c3k1q__product-name {
  font-size: 13px;
  font-weight: 600;
  color: #000;
  line-height: 1.3;
  margin: 0;
}
.sai-sz8c3k1q__product-price {
  font-size: 12px;
  font-weight: 400;
  color: #666;
  margin: 0;
}
.sai-sz8c3k1q__product-variant {
  font-size: 12px;
  font-weight: 600;
  color: #000;
  margin: 2px 0 0;
}
.sai-sz8c3k1q__product-variant:empty {
  display: none;
}

/* ---------- tabs + unit toggle bar ---------- */
.sai-sz8c3k1q__controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid #e5e5e5;
  margin-bottom: 0;
}
.sai-sz8c3k1q__tabs {
  display: flex;
  gap: 20px;
}
.sai-sz8c3k1q__tab {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: 0 0 10px;
  margin: 0;
  font-family: inherit;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #999;
  cursor: pointer;
  white-space: nowrap;
}
.sai-sz8c3k1q__tab[data-active="true"] {
  color: #000;
  border-bottom-color: #000;
}

.sai-sz8c3k1q__unit-toggle {
  display: flex;
  border: 1px solid #ddd;
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 10px;
}
.sai-sz8c3k1q__unit-btn {
  background: #fff;
  border: none;
  padding: 5px 12px;
  font-family: inherit;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #999;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
.sai-sz8c3k1q__unit-btn[data-active="true"] {
  background: #000;
  color: #fff;
}

/* ---------- size chart table ---------- */
.sai-sz8c3k1q__table-panel {
  display: none;
}
.sai-sz8c3k1q__table-panel[data-visible="true"] {
  display: block;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.sai-sz8c3k1q__table {
  min-width: 100%;
  border-collapse: collapse;
  margin-top: 0;
}
.sai-sz8c3k1q__table th {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #999;
  text-align: center;
  padding: 12px 12px;
  border-bottom: 1px solid #e5e5e5;
  white-space: nowrap;
}
.sai-sz8c3k1q__col-radio {
  width: 28px;
  min-width: 28px;
  padding: 0 4px !important;
  text-align: center;
}
.sai-sz8c3k1q__col-size {
  text-align: left;
}
.sai-sz8c3k1q__table th:first-child {
  text-align: left;
}
.sai-sz8c3k1q__table td {
  font-size: 13px;
  font-weight: 400;
  color: #333;
  text-align: center;
  padding: 0 12px;
  height: 44px;
  border-bottom: 1px solid #f0f0f0;
  white-space: nowrap;
}
.sai-sz8c3k1q__table td:first-child {
  text-align: center;
}
.sai-sz8c3k1q__table td:nth-child(2) {
  text-align: left;
}
.sai-sz8c3k1q__table tbody tr {
  cursor: pointer;
}
.sai-sz8c3k1q__table tr:last-child td {
  border-bottom: none;
}

.sai-sz8c3k1q__col-size {
  text-align: left;
}
.sai-sz8c3k1q__radio {
  appearance: none;
  -webkit-appearance: none;
  width: 16px;
  height: 16px;
  border: 1.5px solid #bbb;
  border-radius: 50%;
  cursor: pointer;
  position: relative;
  flex-shrink: 0;
  margin: 0;
}
.sai-sz8c3k1q__radio:checked {
  border-color: #000;
}
.sai-sz8c3k1q__radio:checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #000;
}
.sai-sz8c3k1q__size-label {
  font-size: 13px;
  font-weight: 500;
  color: #000;
}
.sai-sz8c3k1q__row--oos td {
  text-decoration: line-through;
}

/* ---------- how to measure panel ---------- */
.sai-sz8c3k1q__measure-panel {
  display: none;
}
.sai-sz8c3k1q__measure-panel[data-visible="true"] {
  display: block;
}
.sai-sz8c3k1q__measure-media {
  width: 100%;
  max-height: 340px;
  object-fit: cover;
  margin-top: 16px;
  border-radius: 0;
  background: #f5f5f5;
}
.sai-sz8c3k1q__measure-title {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #000;
  margin: 16px 0 6px;
}
.sai-sz8c3k1q__measure-desc {
  font-size: 12px;
  font-weight: 400;
  color: #666;
  line-height: 1.5;
  margin: 0;
}

/* ---------- CTA ---------- */
.sai-sz8c3k1q__cta-wrap {
  margin-top: 20px;
}
.sai-sz8c3k1q__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 44px;
  background: #000;
  color: #fff;
  border: none;
  border-radius: 0;
  font-family: inherit;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity 0.15s;
}
.sai-sz8c3k1q__cta:hover {
  opacity: 0.85;
}
.sai-sz8c3k1q__cta:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.sai-sz8c3k1q__cta--oos {
  background: #666;
  cursor: not-allowed;
}
{% endstylesheet %}

{%- if product -%}
{%- liquid
  comment
    Three-layer resolution: product metafield → slot metaobject → chart metaobject.
    PDP only — requires the product Liquid global.
  endcomment

  assign sai_slot_list = nil
  assign sai_chart_data = nil
  assign sai_guide_media = nil

  assign sai_slot_list = product.metafields.spectrum.size_chart_live.value
  assign sai_guides_list = nil

  if sai_slot_list != blank
    for slot in sai_slot_list
      assign sai_chart_mo = slot.chart.value
      if sai_chart_mo != blank
        assign sai_chart_data = sai_chart_mo.chart_data.value
        assign sai_guides_list = sai_chart_mo.guides.value
      endif
      break
    endfor
  endif
-%}

{%- if sai_chart_data != blank -%}
  <sai-sz8c3k1q class="sai-sz8c3k1q"></sai-sz8c3k1q>

  <script type="application/json" data-spectrum-snippet-pool>
  {
    "size_chart": {{ sai_chart_data | json }},
    "product": {
      "title": {{ product.title | json }},
      "price": {{ product.price | money | json }},
      "compare_at_price": {% if product.compare_at_price > product.price %}{{ product.compare_at_price | money | json }}{% else %}null{% endif %},
      "image": {{ product.featured_image | image_url: width: 200 | json }},
      "url": {{ product.url | json }},
      "options": {{ product.options_with_values | json }},
      "variants": [
        {%- for v in product.variants -%}
          {%- unless forloop.first -%},{%- endunless -%}
          {
            "id": {{ v.id | json }},
            "title": {{ v.title | json }},
            "available": {{ v.available | json }},
            "option1": {{ v.option1 | json }},
            "option2": {{ v.option2 | json }},
            "option3": {{ v.option3 | json }}
          }
        {%- endfor -%}
      ]
    },
    "guides": [
      {%- if sai_guides_list != blank -%}
        {%- assign sai_guide_count = sai_guides_list.size -%}
        {%- for i in (0..sai_guide_count) -%}
          {%- if i >= sai_guide_count -%}{%- break -%}{%- endif -%}
          {%- assign sai_g = nil -%}
          {%- for g in sai_guides_list offset: i limit: 1 -%}
            {%- assign sai_g = g -%}
          {%- endfor -%}
          {%- if sai_g -%}
            {%- unless i == 0 -%},{%- endunless -%}
            {
              "name": {{ sai_g.name.value | json }},
              "description": {{ sai_g.description.value | json }},
              {%- if sai_g.media.value -%}
                "media": {
                  {%- if sai_g.media.value.media_type == 'VIDEO' -%}
                    "url": {{ sai_g.media.value.sources[0].url | json }},
                    "poster": {{ sai_g.media.value.preview_image.src | image_url: width: 800 | json }},
                    "type": "video"
                  {%- else -%}
                    "url": {{ sai_g.media.value.preview_image.src | image_url: width: 800 | json }},
                    "type": "image"
                  {%- endif -%},
                  "alt": {{ sai_g.media.value.alt | json }}
                }
              {%- else -%}
                "media": null
              {%- endif -%}
            }
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    ],
    "props": {
      "trigger_style": {{ props.trigger_style | default: 'link' | json }},
      "open_mode": {{ props.open_mode | default: 'modal' | json }},
      "drawer_direction": {{ props.drawer_direction | default: 'right' | json }},
      "show_headers": {% if props.show_headers == nil %}true{% else %}{{ props.show_headers | json }}{% endif %},
      "show_unit_toggle": {% if props.show_unit_toggle == nil %}true{% else %}{{ props.show_unit_toggle | json }}{% endif %},
      "default_unit": {{ props.default_unit | default: 'inch' | json }},
      "show_atc": {% if props.show_atc == nil %}true{% else %}{{ props.show_atc | json }}{% endif %},
      "auto_select_variant": {% if props.auto_select_variant == nil %}false{% else %}{{ props.auto_select_variant | json }}{% endif %}
    }
  }
  </script>
{%- endif -%}

<script src="{{ 'sai-snippet-sz8c3k1q.js' | asset_url }}" async></script>
{%- endif -%}
