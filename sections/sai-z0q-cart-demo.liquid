{%- comment -%}z0q31ww1 demo + inline cart-discount data. Variant content read from
  spectrum_snippet_instance metaobject so promo blocks are exercised.{%- endcomment -%}
<div data-sai-cart-data hidden style="display:none">{
  "discountsByVariant": {
    {%- assign sai_first = true -%}
    {%- for item in cart.items -%}
      {%- assign v_raw = item.variant.metafields.spectrum.discounts.value -%}
      {%- if v_raw != blank -%}
        {%- unless sai_first -%},{%- endunless -%}
        {{ item.variant.id | append: '' | json }}: {{ v_raw | json }}
        {%- assign sai_first = false -%}
      {%- endif -%}
    {%- endfor -%}
  },
  "cart": {
    "subtotal": {{ cart.items_subtotal_price | divided_by: 100.0 | json }},
    "appliedCodes": [
      {%- assign ac_first = true -%}
      {%- for app in cart.cart_level_discount_applications -%}
        {%- if app.type == 'discount_code' -%}
          {%- unless ac_first -%},{%- endunless -%}
          {{ app.title | upcase | json }}
          {%- assign ac_first = false -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  }
}</div>
{%- assign sai_z0q_mo = metaobjects.spectrum_snippet_instance['spectrum_snippet_z0q31ww1_promotest_live'] -%}
{%- assign sai_z0q_variant = sai_z0q_mo.variants.value.variants[0] -%}
{% render '_sai-snippet-z0q31ww1', variant: sai_z0q_variant, mutation_handle: 'mut-9wbjxpgqa9', experience_handle: '_system-196419092640' %}
{% schema %}
{ "name": "Z0Q demo", "presets": [{ "name": "Z0Q demo" }] }
{% endschema %}
