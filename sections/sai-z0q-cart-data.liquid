{%- comment -%}Cart discounts JSON emitter for z0q31ww1.{%- endcomment -%}
<script type="application/json" data-sai-cart-data>
{
  "_sectionRan": true,
  "_cartItemCount": {{ cart.item_count | json }},
  "discountsByVariant": {
    {%- assign sai_first = true -%}
    {%- for item in cart.items -%}
      {%- assign v_raw = item.variant.metafields.spectrum.discounts.value -%}
      {%- if v_raw != blank -%}
        {%- unless sai_first -%},{%- endunless -%}
        {{ item.variant.id | append: '' | json }}: {{ v_raw | json }}
        {%- assign sai_first = false -%}
      {%- endif -%}
    {%- endfor -%}
  }
}
</script>
{% schema %}
{ "name": "Z0Q cart data" }
{% endschema %}