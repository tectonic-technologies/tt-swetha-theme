{%- comment -%}
  SPECTRUM DEMO — Explore Our Range shoppable grid (snippet ryi2st97).
  Self-contained sample-data host (no Spectrum metaobjects): real products via
  all_products, Figma category images as assets/sai-explore-N.jpg, sample
  hotspot coordinates. Remove this section + templates/page.explore-demo +
  the sai-explore-*.jpg assets to clean up.
{%- endcomment -%}
{%- assign tiles = 'frido HOME~sai-explore-1.jpg~the-complete-snowboard:66:33|frido-ultimate-cozy-pillow:52:83|the-collection-snowboard-hydrogen:32:50|the-compare-at-price-snowboard:43:43|the-collection-snowboard-oxygen:66:67|the-collection-snowboard-liquid:83:77;;frido ORTHOTICS~sai-explore-2.jpg~frido-ultimate-mattress-topper:40:45|the-hidden-snowboard:70:62;;frido WORK~sai-explore-3.jpg~the-complete-snowboard:35:42|the-videographer-snowboard:66:66;;frido TRAVEL~sai-explore-4.jpg~frido-ultimate-cozy-pillow:50:48;;frido WALK~sai-explore-5.jpg~the-multi-location-snowboard:42:40|the-multi-managed-snowboard:66:66;;frido DRIVE~sai-explore-6.jpg~the-collection-snowboard-oxygen:46:50;;frido MOBILITY~sai-explore-7.jpg~the-complete-snowboard:30:52|frido-ultimate-mattress-topper:55:46|the-compare-at-price-snowboard:76:60' | split: ';;' -%}

<div
  data-spectrum-snippet-id="ryi2st97"
  data-spectrum-instance-id="demo"
  data-spectrum-vis="on"
  data-spectrum-experience="explore-demo"
  style="display:block;padding:48px 0;"
>
  <sai-ryi2st97
    class="sai-ryi2st97"
    data-layout="bento"
    data-cols="3"
    data-hotspots="true"
    data-mini-pdp="true"
    data-cta-label="Shop Now"
    data-cta-text="Add to Cart"
  >
    <header class="sai-ryi2st97__header">
      <h2 class="sai-ryi2st97__section-title">Explore Our Range</h2>
      <div class="sai-ryi2st97__nav" data-sai-nav>
        <button type="button" class="sai-ryi2st97__nav-btn" data-sai-prev aria-label="Previous"><svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <button type="button" class="sai-ryi2st97__nav-btn" data-sai-next aria-label="Next"><svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      </div>
    </header>
    <div class="sai-ryi2st97__grid" role="list">
      {%- for t in tiles -%}
        <div class="sai-ryi2st97__tile sai-ryi2st97__tile--placeholder" data-handle="tile-{{ forloop.index }}" role="listitem"></div>
      {%- endfor -%}
    </div>
  </sai-ryi2st97>

  <script type="application/json" data-spectrum-snippet-pool>
  {
    "cards": {
      {%- for t in tiles -%}
        {%- assign parts = t | split: '~' -%}
        {%- assign label = parts[0] -%}
        {%- assign img = parts[1] -%}
        {%- assign pins = parts[2] | split: '|' -%}
        {%- unless forloop.first -%},{%- endunless -%}
        "tile-{{ forloop.index }}": {
          "title": {{ label | json }},
          "cta_url": null,
          "tile_image": {{ img | asset_url | json }},
          "tagged_products": [
            {%- for pin in pins -%}
              {%- assign pp = pin | split: ':' -%}
              {%- assign prod = all_products[pp[0]] -%}
              {%- if prod and prod.id -%}
                {%- unless forloop.first -%},{%- endunless -%}
                {%- assign tv = prod.selected_or_first_available_variant -%}
                {%- assign sv = false -%}{%- if prod.variants.size == 1 -%}{%- assign sv = true -%}{%- endif -%}
                {%- assign sc = false -%}{%- if tv.compare_at_price > tv.price -%}{%- assign sc = true -%}{%- endif -%}
                {%- assign thumb = '' -%}{%- if prod.featured_image -%}{%- assign thumb = prod.featured_image | image_url: width: 320 -%}{%- endif -%}
                {
                  "tag_id": {{ pp[0] | json }},
                  "product_id": {{ prod.id | json }},
                  "handle": {{ prod.handle | json }},
                  "display_name": {{ prod.title | json }},
                  "thumb_url": {{ thumb | json }},
                  "product_url": {{ prod.url | json }},
                  "single_variant": {{ sv | json }},
                  "variant_id": {{ tv.id | json }},
                  "variant_available": {{ tv.available | json }},
                  "variant_price": {{ tv.price | money | json }},
                  "variant_compare_at_price": {{ tv.compare_at_price | money | json }},
                  "show_compare": {{ sc | json }},
                  "price_override": null
                }
              {%- endif -%}
            {%- endfor -%}
          ],
          "pins": [
            {%- for pin in pins -%}
              {%- assign pp = pin | split: ':' -%}
              {%- assign prod = all_products[pp[0]] -%}
              {%- if prod and prod.id -%}
                {%- unless forloop.first -%},{%- endunless -%}
                {
                  "tag_id": {{ pp[0] | json }},
                  "product_id": {{ prod.id | json }},
                  "hotspot_x": {{ pp[1] | json }},
                  "hotspot_y": {{ pp[2] | json }}
                }
              {%- endif -%}
            {%- endfor -%}
          ]
        }
      {%- endfor -%}
    }
  }
  </script>

  <script src="{{ 'sai-snippet-ryi2st97.js' | asset_url }}" defer></script>
</div>

{% stylesheet %}
  .sai-ryi2st97 {
    --sai-ryi2st97-maxw: 1200px;
    --sai-ryi2st97-gap: 16px;
    --sai-ryi2st97-radius: 16px;
    --sai-ryi2st97-fg: var(--color-foreground, #131313);
    --sai-ryi2st97-bg: var(--color-background, #ffffff);
    --sai-ryi2st97-accent: var(--color-button, #fcd00b);
    --sai-ryi2st97-accent-text: #131313;
    --sai-ryi2st97-muted: #8a8a8a;
    --sai-ryi2st97-pdp-radius: 24px;
    --sai-ryi2st97-pin-bg: rgba(0, 0, 0, 0.65);
    --sai-ryi2st97-pin-dot: #f7f7f7;
    display: block;
    width: 100%;
    max-width: var(--sai-ryi2st97-maxw);
    margin: 0 auto;
    padding: 0 16px;
    box-sizing: border-box;
    font-family: var(--font-body-family, "Outfit", sans-serif);
  }
  .sai-ryi2st97 *,
  .sai-ryi2st97 *::before,
  .sai-ryi2st97 *::after {
    box-sizing: border-box;
  }

  .sai-ryi2st97__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 32px;
  }
  .sai-ryi2st97__section-title {
    margin: 0;
    font-family: var(--font-heading-family, "Outfit", sans-serif);
    font-weight: 500;
    font-size: clamp(22px, 2.4vw, 28px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--sai-ryi2st97-fg);
  }
  @supports (background-clip: text) or (-webkit-background-clip: text) {
    .sai-ryi2st97__section-title {
      background: linear-gradient(101deg, #131313 0%, #ffe46b 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
  }
  .sai-ryi2st97__nav {
    display: flex;
    gap: 8px;
    flex: none;
  }
  .sai-ryi2st97__nav-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #f7f7f7;
    color: #131313;
    border: 0;
    display: grid;
    place-items: center;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.15s ease, background 0.15s ease;
  }
  .sai-ryi2st97__nav-btn:disabled {
    opacity: 0.4;
    cursor: default;
  }
  .sai-ryi2st97__nav-btn svg {
    width: 14px;
    height: 14px;
  }

  /* ── Grid ── */
  .sai-ryi2st97__grid {
    position: relative;
    width: 100%;
  }

  /* Bento: % positioning baked from the 1200×1452 Figma mosaic. */
  .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__grid {
    aspect-ratio: 1200 / 1452;
  }
  .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__tile {
    position: absolute;
  }
  .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__tile:nth-child(1) {
    left: 0;
    top: 0;
    width: 64.667%;
    height: 38.567%;
  }
  .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__tile:nth-child(2) {
    left: 66%;
    top: 0;
    width: 34%;
    height: 31.680%;
  }
  .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__tile:nth-child(3) {
    left: 0;
    top: 39.669%;
    width: 35%;
    height: 27.548%;
  }
  .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__tile:nth-child(4) {
    left: 36.333%;
    top: 39.669%;
    width: 28.333%;
    height: 27.548%;
  }
  .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__tile:nth-child(5) {
    left: 66%;
    top: 32.782%;
    width: 33.333%;
    height: 34.435%;
  }
  .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__tile:nth-child(6) {
    left: 0;
    top: 68.320%;
    width: 35%;
    height: 31.680%;
  }
  .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__tile:nth-child(7) {
    left: 36.333%;
    top: 68.320%;
    width: 63.667%;
    height: 31.680%;
  }

  /* Uniform grid fallback (and bento with ≠7 cards via the --fallback flag). */
  .sai-ryi2st97[data-layout="grid"] .sai-ryi2st97__grid,
  .sai-ryi2st97--grid-fallback .sai-ryi2st97__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sai-ryi2st97-gap);
    aspect-ratio: auto;
  }
  .sai-ryi2st97[data-layout="grid"] .sai-ryi2st97__tile,
  .sai-ryi2st97--grid-fallback .sai-ryi2st97__tile {
    position: relative;
    aspect-ratio: 4 / 3;
  }

  /* ── Tile ── */
  .sai-ryi2st97__tile {
    display: block;
    border-radius: var(--sai-ryi2st97-radius);
    overflow: hidden;
    background: #ededed;
    isolation: isolate;
  }
  .sai-ryi2st97__tile-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .sai-ryi2st97__tile-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 38%,
      rgba(0, 0, 0, 0.78) 92%
    );
    pointer-events: none;
  }
  .sai-ryi2st97__tile-bar {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: clamp(14px, 1.6vw, 24px);
  }
  .sai-ryi2st97__tile-bar-left {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }
  .sai-ryi2st97__tile-label {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-heading-family, "Outfit", sans-serif);
    font-weight: 600;
    font-size: clamp(15px, 1.5vw, 22px);
    line-height: 1.1;
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sai-ryi2st97__tile-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 16px;
    border-radius: 8px;
    background: #131313;
    color: #ffffff;
    font-family: var(--font-heading-family, "Outfit", sans-serif);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.18s ease, transform 0.18s ease;
    pointer-events: none;
  }
  .sai-ryi2st97__tile:hover .sai-ryi2st97__tile-cta,
  .sai-ryi2st97__tile:focus-within .sai-ryi2st97__tile-cta {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .sai-ryi2st97__tile-arrow {
    flex: none;
    width: clamp(34px, 3vw, 40px);
    height: clamp(34px, 3vw, 40px);
    border-radius: 50%;
    background: #ffffff;
    color: #131313;
    border: 0;
    display: grid;
    place-items: center;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.15s ease;
  }
  .sai-ryi2st97__tile-arrow:hover {
    transform: scale(1.06);
  }
  .sai-ryi2st97__tile-arrow svg {
    width: 42%;
    height: 42%;
  }

  /* ── Hotspot pins ── */
  .sai-ryi2st97__pins {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }
  .sai-ryi2st97__pin {
    position: absolute;
    left: var(--sai-x, 50%);
    top: var(--sai-y, 50%);
    transform: translate(-50%, -50%);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 0;
    padding: 0;
    background: var(--sai-ryi2st97-pin-bg);
    display: grid;
    place-items: center;
    cursor: pointer;
    pointer-events: auto;
    color: currentColor;
  }
  .sai-ryi2st97__pin::after {
    content: "";
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--sai-ryi2st97-pin-dot);
  }
  .sai-ryi2st97__pin::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.45);
    animation: sai-ryi2st97-pulse 2.4s ease-out infinite;
  }
  .sai-ryi2st97__pin--active {
    background: var(--sai-ryi2st97-accent);
  }
  .sai-ryi2st97__pin--active::after {
    background: var(--sai-ryi2st97-accent-text);
  }
  @keyframes sai-ryi2st97-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.5);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(255, 255, 255, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
    }
  }

  /* ── Mini-PDP popup ── */
  .sai-ryi2st97__pdp-backdrop {
    position: fixed;
    inset: 0;
    z-index: 2147483000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 16px;
    background: rgba(0, 0, 0, 0.45);
  }
  .sai-ryi2st97__pdp-backdrop[data-open="true"] {
    display: flex;
  }
  .sai-ryi2st97__pdp {
    position: relative;
    width: 100%;
    max-width: 420px;
    max-height: 92vh;
    overflow-y: auto;
    background: var(--sai-ryi2st97-bg);
    border-radius: var(--sai-ryi2st97-pdp-radius);
    padding: 16px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
    font-family: var(--font-body-family, "Outfit", sans-serif);
  }
  .sai-ryi2st97__pdp-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }
  .sai-ryi2st97__pdp-title {
    margin: 0;
    font-family: var(--font-heading-family, "Outfit", sans-serif);
    font-weight: 500;
    font-size: 20px;
    line-height: 1.2;
    color: var(--sai-ryi2st97-fg);
  }
  .sai-ryi2st97__pdp-close {
    flex: none;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 0;
    background: transparent;
    color: var(--sai-ryi2st97-fg);
    cursor: pointer;
    display: grid;
    place-items: center;
  }
  .sai-ryi2st97__pdp-close svg {
    width: 16px;
    height: 16px;
  }
  .sai-ryi2st97__pdp-gallery {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 1fr;
    gap: 8px;
    margin-bottom: 14px;
  }
  .sai-ryi2st97__pdp-thumb {
    aspect-ratio: 1 / 1;
    border-radius: 16px;
    overflow: hidden;
    background: #f0f0f0;
  }
  .sai-ryi2st97__pdp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sai-ryi2st97__pdp-group {
    margin-bottom: 14px;
  }
  .sai-ryi2st97__pdp-group-label {
    display: block;
    font-size: 13px;
    color: var(--sai-ryi2st97-muted);
    margin-bottom: 8px;
  }
  .sai-ryi2st97__pdp-group-label b {
    color: var(--sai-ryi2st97-fg);
    font-weight: 600;
  }
  .sai-ryi2st97__pdp-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .sai-ryi2st97__swatch {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 0;
    padding: 2px;
    background: transparent;
    cursor: pointer;
    box-shadow: inset 0 0 0 2px transparent;
  }
  .sai-ryi2st97__swatch-dot {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(0, 0, 0, 0.1);
  }
  .sai-ryi2st97__swatch[aria-pressed="true"] {
    box-shadow: inset 0 0 0 2px var(--sai-ryi2st97-accent);
  }
  .sai-ryi2st97__swatch[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .sai-ryi2st97__swatch--text {
    width: auto;
    height: auto;
    padding: 7px 12px;
    border-radius: 8px;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.18);
    font-size: 13px;
    color: var(--sai-ryi2st97-fg);
  }
  .sai-ryi2st97__swatch--text[aria-pressed="true"] {
    box-shadow: inset 0 0 0 2px var(--sai-ryi2st97-accent);
  }
  .sai-ryi2st97__pdp-price {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    margin: 4px 0 14px;
  }
  .sai-ryi2st97__pdp-price-now {
    font-weight: 700;
    font-size: 18px;
    color: var(--sai-ryi2st97-fg);
  }
  .sai-ryi2st97__pdp-price-was {
    font-size: 13px;
    color: var(--sai-ryi2st97-muted);
    text-decoration: line-through;
  }
  .sai-ryi2st97__pdp-badge {
    font-size: 11px;
    font-weight: 600;
    color: #0f7a3d;
    background: #e3f5e9;
    border-radius: 4px;
    padding: 2px 6px;
  }
  .sai-ryi2st97__pdp-tax {
    flex-basis: 100%;
    font-size: 12px;
    font-weight: 300;
    color: #bcbcbc;
  }
  .sai-ryi2st97__pdp-cta {
    width: 100%;
    border: 0;
    border-radius: 16px;
    height: 52px;
    background: var(--sai-ryi2st97-accent);
    color: var(--sai-ryi2st97-accent-text);
    font-family: var(--font-heading-family, "Outfit", sans-serif);
    font-weight: 600;
    font-size: 18px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .sai-ryi2st97__pdp-cta[data-loading="1"] {
    opacity: 0.7;
    cursor: progress;
  }
  .sai-ryi2st97__pdp-spinner {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid currentColor;
    border-right-color: transparent;
    animation: sai-ryi2st97-spin 0.7s linear infinite;
  }
  @keyframes sai-ryi2st97-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ── Accessibility / motion ── */
  .sai-ryi2st97__pin:focus-visible,
  .sai-ryi2st97__tile-arrow:focus-visible,
  .sai-ryi2st97__nav-btn:focus-visible,
  .sai-ryi2st97__pdp-cta:focus-visible,
  .sai-ryi2st97__swatch:focus-visible {
    outline: 2px solid var(--sai-ryi2st97-accent);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .sai-ryi2st97__pin::before,
    .sai-ryi2st97__pdp-spinner {
      animation: none;
    }
    .sai-ryi2st97__tile-cta,
    .sai-ryi2st97__tile-arrow {
      transition: none;
    }
  }

  /* ── Mobile: bento collapses to a horizontal snap carousel ── */
  @media screen and (max-width: 749px) {
    .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__grid {
      aspect-ratio: auto;
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .sai-ryi2st97[data-layout="bento"] .sai-ryi2st97__grid::-webkit-scrollbar {
      display: none;
    }
